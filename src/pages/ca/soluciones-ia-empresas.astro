---
import Layout from '../../layouts/Layout.astro';
import SolucionesIAPage from '../../components/SolucionesIAPage.astro';
import '../../styles/global.css';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Solucions IA per a Empreses",
  "description": "CIBAI.Studio resol problemes reals de negoci mitjançant IA, automatització, software a mida i actius digitals. Solucions adaptades al context de cada empresa.",
  "provider": {
    "@type": "Organization",
    "name": "CIBAI.Studio",
    "url": "https://cibai.studio"
  },
  "serviceType": "Solucions d'Intel·ligència Artificial per a empreses",
  "areaServed": {
    "@type": "Country",
    "name": "España"
  },
  "url": "https://cibai.studio/ca/soluciones-ia-empresas",
  "offers": {
    "@type": "Offer",
    "description": "Diagnòstic inicial gratuït per identificar les solucions amb major impacte per a la teva empresa",
    "url": "https://cibai.studio/ca/contacto"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inici",
      "item": "https://cibai.studio/ca/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Solucions IA per a Empreses",
      "item": "https://cibai.studio/ca/soluciones-ia-empresas"
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Quin tipus de solucions ofereix CIBAI.Studio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "CIBAI.Studio ofereix sis línies de servei: IA i Automatització de processos, Agents IA i RAG, Veu IA i Centraletes, Software a Mida, Web Corporativa i Ecommerce a Mida. Es poden aplicar de forma aïllada o combinades per construir la solució completa que necessita cada empresa."
      }
    },
    {
      "@type": "Question",
      "name": "Per on es comença a treballar amb CIBAI.Studio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El punt de partida és un diagnòstic gratuït de 30 minuts. Analitzem la situació de l'empresa i identifiquem quines solucions tindrien més impacte, en quin ordre i amb quin cost aproximat."
      }
    },
    {
      "@type": "Question",
      "name": "Quant temps tarda a veure's el retorn de les solucions implementades?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Depèn de la solució. Les automatitzacions de processos poden generar retorn en poques setmanes en reduir hores de treball manual. Els projectes de software a mida o agents IA poden requerir 1-3 mesos d'implementació abans de veure l'impacte complet."
      }
    }
  ]
};
---

<Layout
  title="Solucions IA per a Empreses | CIBAI.Studio"
  description="CIBAI.Studio resol problemes reals de negoci mitjançant IA, automatització, software a mida i actius digitals. Diagnòstic gratuït per a la teva empresa."
  locale="ca"
  canonicalPath="/ca/soluciones-ia-empresas"
  hreflangEs="https://cibai.studio/soluciones-ia-empresas"
  hreflangCa="https://cibai.studio/ca/soluciones-ia-empresas"
  schemaMarkup={[serviceSchema, breadcrumbSchema, faqSchema]}
>
  <SolucionesIAPage locale="ca" />
</Layout>
