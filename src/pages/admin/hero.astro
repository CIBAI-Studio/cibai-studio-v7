---
import AdminLayout from '../../layouts/AdminLayout.astro';
import '../../styles/global.css';
import { getAuthUser } from '../../lib/auth';
import {
  loadSettings,
  saveSettings,
  generateSlideId,
  type HeroSlide,
  type HeroSlideButton,
} from '../../lib/settings';
import { locales, getLocaleLabels } from '../../i18n';

const user = getAuthUser(Astro.cookies);
if (!user) return Astro.redirect('/admin/login');

const settings = loadSettings();
let successMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('_action') as string;

  if (action === 'save_all') {
    const slideIds = formData.getAll('slide_id') as string[];
    const updatedSlides: HeroSlide[] = [];

    for (let i = 0; i < slideIds.length; i++) {
      const id = slideIds[i];
      const existing = settings.heroSlides.find(s => s.id === id);
      if (!existing) continue;

      // Badges per locale
      const badges: Record<string, string[]> = {};
      for (const loc of locales) {
        const arr: string[] = [];
        let bIdx = 0;
        while (formData.has(`badge_${loc}_${id}_${bIdx}`)) {
          const v = (formData.get(`badge_${loc}_${id}_${bIdx}`) as string || '').trim();
          if (v) arr.push(v);
          bIdx++;
        }
        badges[loc] = arr;
      }

      // Heading per locale
      const heading: Record<string, { line1: string; line2: string; line3: string; full: string }> = {};
      for (const loc of locales) {
        heading[loc] = {
          line1: (formData.get(`heading_line1_${loc}_${id}`) as string) || '',
          line2: (formData.get(`heading_line2_${loc}_${id}`) as string) || '',
          line3: (formData.get(`heading_line3_${loc}_${id}`) as string) || '',
          full:  (formData.get(`heading_full_${loc}_${id}`) as string) || '',
        };
      }

      // Subtitle per locale
      const subtitle: Record<string, string> = {};
      for (const loc of locales) {
        subtitle[loc] = (formData.get(`subtitle_${loc}_${id}`) as string) || '';
      }

      // Terminal per locale
      const terminal: Record<string, { cmd: string; flag: string; lines: string[] }> = {};
      for (const loc of locales) {
        const lines: string[] = [];
        let lIdx = 0;
        while (formData.has(`terminal_line_${loc}_${id}_${lIdx}`)) {
          const v = (formData.get(`terminal_line_${loc}_${id}_${lIdx}`) as string) || '';
          lines.push(v);
          lIdx++;
        }
        terminal[loc] = {
          cmd:   (formData.get(`terminal_cmd_${loc}_${id}`) as string) || '',
          flag:  (formData.get(`terminal_flag_${loc}_${id}`) as string) || '',
          lines,
        };
      }

      // Buttons
      const buttons: HeroSlideButton[] = [];
      let btnIdx = 0;
      while (formData.has(`btn_href_${id}_${btnIdx}`)) {
        const href = (formData.get(`btn_href_${id}_${btnIdx}`) as string) || '';
        const label: Record<string, string> = {};
        for (const loc of locales) {
          label[loc] = (formData.get(`btn_label_${loc}_${id}_${btnIdx}`) as string) || '';
        }
        const style = (formData.get(`btn_style_${id}_${btnIdx}`) as string) === 'secondary' ? 'secondary' : 'primary';
        buttons.push({ href, label, style });
        btnIdx++;
      }

      // Microcopy (optional)
      const microcopy: Record<string, string> = {};
      let hasMicrocopy = false;
      for (const loc of locales) {
        const v = (formData.get(`microcopy_${loc}_${id}`) as string || '').trim();
        if (v) { microcopy[loc] = v; hasMicrocopy = true; }
      }

      updatedSlides.push({
        id,
        active:      formData.has(`active_${id}`),
        order:       i,
        duration:    Math.min(60, Math.max(1, parseInt((formData.get(`duration_${id}`) as string) || '6', 10))),
        accentColor: (formData.get(`accent_${id}`) as string) === 'teal' ? 'teal' : 'orange',
        badges,
        heading,
        subtitle,
        terminal,
        buttons,
        ...(hasMicrocopy ? { microcopy } : {}),
      });
    }

    settings.heroSlides = updatedSlides;
    saveSettings(settings);
    successMessage = 'Hero slides guardados correctamente.';
  }

  if (action === 'create') {
    const newIdx = settings.heroSlides.length;
    const newSlide: HeroSlide = {
      id:          generateSlideId(),
      active:      true,
      order:       newIdx,
      duration:    6,
      accentColor: 'orange',
      badges:      { es: ['BADGE_1', 'BADGE_2', 'BADGE_3'], ca: ['BADGE_1', 'BADGE_2', 'BADGE_3'] },
      heading: {
        es: { line1: 'TÍTULO LÍNEA 1', line2: 'TÍTULO LÍNEA 2', line3: 'TÍTULO LÍNEA 3', full: 'Título completo del slide.' },
        ca: { line1: 'TÍTOL LÍNIA 1',  line2: 'TÍTOL LÍNIA 2',  line3: 'TÍTOL LÍNIA 3',  full: 'Títol complet del slide.' },
      },
      subtitle:    { es: 'Subtítulo del slide en castellano.', ca: 'Subtítol del slide en català.' },
      terminal: {
        es: { cmd: 'cibai', flag: '--flag', lines: ['> Línea 1', '> Línea 2', '> Línea 3'] },
        ca: { cmd: 'cibai', flag: '--flag', lines: ['> Línia 1', '> Línia 2', '> Línia 3'] },
      },
      buttons: [
        { href: '#contacto', label: { es: 'Acción principal', ca: 'Acció principal' }, style: 'primary' },
        { href: '#servicios', label: { es: 'Acción secundaria', ca: 'Acció secundària' }, style: 'secondary' },
      ],
    };
    settings.heroSlides.push(newSlide);
    saveSettings(settings);
    successMessage = 'Slide creado. Edítalo a continuación.';
  }

  if (action === 'delete') {
    const deleteId = formData.get('delete_id') as string;
    settings.heroSlides = settings.heroSlides
      .filter(s => s.id !== deleteId)
      .map((s, i) => ({ ...s, order: i }));
    saveSettings(settings);
    successMessage = 'Slide eliminado.';
  }
}

const localeLabels = getLocaleLabels();
const slides = [...settings.heroSlides].sort((a, b) => a.order - b.order);
---

<AdminLayout title="Hero Slides" userName={user.name}>
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-black tracking-tight mb-2">Hero Slides</h1>
      <p class="text-sm text-cyber-text font-mono">
        Arrastra para reordenar. Cada slide se renderiza en el carrusel del hero. Idiomas: ES / CA.
      </p>
    </div>
    <form method="POST">
      <input type="hidden" name="_action" value="create" />
      <button type="submit" class="btn-primary text-xs py-2 px-5">+ Nuevo slide</button>
    </form>
  </div>

  {successMessage && (
    <div class="mb-6 px-4 py-3 border border-cyber-teal/30 bg-cyber-teal/5 text-cyber-teal font-mono text-xs">
      {successMessage}
    </div>
  )}

  <form method="POST" id="main-form">
    <input type="hidden" name="_action" value="save_all" />

    <div id="slides-container">
      {slides.map((slide) => (
        <div
          class="slide-card card-brutal mb-6 border border-cyber-border"
          draggable="true"
          data-slide-id={slide.id}
        >
          <input type="hidden" name="slide_id" value={slide.id} />

          {/* ── Card Header ── */}
          <div class="flex items-center gap-3 px-6 py-4 border-b border-cyber-border/50 drag-handle cursor-grab active:cursor-grabbing">
            {/* Drag icon */}
            <span class="text-cyber-text/40 select-none font-mono text-lg leading-none" title="Arrastrar para reordenar">⠿</span>

            {/* Active toggle */}
            <label class="flex items-center gap-2 cursor-pointer" title="Activar/Desactivar slide">
              <input
                type="checkbox"
                name={`active_${slide.id}`}
                checked={slide.active}
                class="sr-only peer"
              />
              <span class="relative inline-block w-8 h-4 bg-cyber-border peer-checked:bg-cyber-teal transition-colors rounded-full">
                <span class="absolute left-0.5 top-0.5 w-3 h-3 bg-cyber-text peer-checked:bg-cyber-black peer-checked:left-4 transition-all rounded-full"></span>
              </span>
              <span class="font-mono text-[10px] uppercase tracking-widest text-cyber-text peer-checked:text-cyber-teal transition-colors">
                {slide.active ? 'Activo' : 'Inactivo'}
              </span>
            </label>

            <span class="flex-1 font-mono text-sm font-bold text-cyber-white truncate">
              <span class="text-cyber-orange">[{slide.order + 1}]</span>
              {' '}— {slide.heading.es?.line1 || slide.id}
            </span>

            <button
              type="button"
              class="font-mono text-[10px] text-cyber-red hover:text-cyber-red/80 uppercase tracking-widest transition-colors delete-btn"
              data-id={slide.id}
              data-name={slide.heading.es?.line1 || slide.id}
            >
              Eliminar
            </button>

            <button
              type="button"
              class="font-mono text-[10px] text-cyber-text hover:text-cyber-white uppercase tracking-widest transition-colors toggle-expand-btn"
              data-target={`slide-body-${slide.id}`}
            >
              ▸ Editar
            </button>
          </div>

          {/* ── Card Body (collapsible) ── */}
          <div id={`slide-body-${slide.id}`} class="slide-body hidden px-6 py-6 space-y-8">

            {/* ── Basic Settings ── */}
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">
                  Duración (seg)
                </label>
                <input
                  type="number"
                  name={`duration_${slide.id}`}
                  value={slide.duration}
                  min="1"
                  max="60"
                  class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors"
                />
              </div>
              <div>
                <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">
                  Color de acento
                </label>
                <select
                  name={`accent_${slide.id}`}
                  class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors"
                >
                  <option value="orange" selected={slide.accentColor === 'orange'}>Orange</option>
                  <option value="teal"   selected={slide.accentColor === 'teal'}>Teal</option>
                </select>
              </div>
            </div>

            {/* ── Badges per locale ── */}
            {locales.map((loc) => (
              <div class="p-4 border border-cyber-border/50 bg-cyber-black/50">
                <div class="font-mono text-[10px] text-cyber-orange uppercase tracking-widest mb-3">
                  Badges — {localeLabels[loc]} ({loc.toUpperCase()})
                </div>
                <div
                  class="space-y-2 badges-container"
                  data-slide-id={slide.id}
                  data-locale={loc}
                >
                  {(slide.badges[loc] || []).map((badge, bIdx) => (
                    <div class="flex items-center gap-2 badge-row">
                      <input
                        type="text"
                        name={`badge_${loc}_${slide.id}_${bIdx}`}
                        value={badge}
                        placeholder="BADGE_TEXT"
                        class="flex-1 bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-xs text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors"
                      />
                      <button
                        type="button"
                        class="text-cyber-red text-sm font-mono hover:text-cyber-red/80 remove-badge-btn"
                        title="Eliminar badge"
                      >
                        &times;
                      </button>
                    </div>
                  ))}
                </div>
                <button
                  type="button"
                  class="mt-2 font-mono text-[10px] text-cyber-teal hover:text-cyber-teal/80 uppercase tracking-widest add-badge-btn"
                  data-slide-id={slide.id}
                  data-locale={loc}
                  data-next-idx={(slide.badges[loc] || []).length}
                >
                  + Añadir badge
                </button>
              </div>
            ))}

            {/* ── Heading per locale ── */}
            {locales.map((loc) => (
              <div class="p-4 border border-cyber-border/50 bg-cyber-black/50">
                <div class="font-mono text-[10px] text-cyber-orange uppercase tracking-widest mb-3">
                  Heading — {localeLabels[loc]} ({loc.toUpperCase()})
                </div>
                <div class="space-y-3">
                  <div>
                    <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">
                      Línea 1
                    </label>
                    <input
                      type="text"
                      name={`heading_line1_${loc}_${slide.id}`}
                      value={slide.heading[loc]?.line1 || ''}
                      class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors"
                    />
                  </div>
                  <div>
                    <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">
                      Línea 2
                    </label>
                    <input
                      type="text"
                      name={`heading_line2_${loc}_${slide.id}`}
                      value={slide.heading[loc]?.line2 || ''}
                      class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors"
                    />
                  </div>
                  <div>
                    <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">
                      Línea 3
                    </label>
                    <input
                      type="text"
                      name={`heading_line3_${loc}_${slide.id}`}
                      value={slide.heading[loc]?.line3 || ''}
                      class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors"
                    />
                  </div>
                  <div>
                    <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">
                      Texto completo (accesibilidad / SEO)
                    </label>
                    <textarea
                      name={`heading_full_${loc}_${slide.id}`}
                      rows="2"
                      class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors resize-none"
                    >{slide.heading[loc]?.full || ''}</textarea>
                  </div>
                </div>
              </div>
            ))}

            {/* ── Subtitle per locale ── */}
            {locales.map((loc) => (
              <div class="p-4 border border-cyber-border/50 bg-cyber-black/50">
                <div class="font-mono text-[10px] text-cyber-orange uppercase tracking-widest mb-3">
                  Subtítulo — {localeLabels[loc]} ({loc.toUpperCase()})
                </div>
                <textarea
                  name={`subtitle_${loc}_${slide.id}`}
                  rows="3"
                  class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors resize-none"
                >{slide.subtitle[loc] || ''}</textarea>
              </div>
            ))}

            {/* ── Terminal per locale ── */}
            {locales.map((loc) => (
              <div class="p-4 border border-cyber-border/50 bg-cyber-black/50">
                <div class="font-mono text-[10px] text-cyber-orange uppercase tracking-widest mb-3">
                  Terminal — {localeLabels[loc]} ({loc.toUpperCase()})
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-3">
                  <div>
                    <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">
                      Comando
                    </label>
                    <input
                      type="text"
                      name={`terminal_cmd_${loc}_${slide.id}`}
                      value={slide.terminal[loc]?.cmd || ''}
                      placeholder="cibai"
                      class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors"
                    />
                  </div>
                  <div>
                    <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">
                      Flag
                    </label>
                    <input
                      type="text"
                      name={`terminal_flag_${loc}_${slide.id}`}
                      value={slide.terminal[loc]?.flag || ''}
                      placeholder="--flag"
                      class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors"
                    />
                  </div>
                </div>
                <div class="font-mono text-[10px] text-cyber-text uppercase tracking-widest mb-2">Líneas de salida</div>
                <div
                  class="space-y-2 terminal-lines-container"
                  data-slide-id={slide.id}
                  data-locale={loc}
                >
                  {(slide.terminal[loc]?.lines || []).map((line, lIdx) => (
                    <div class="flex items-center gap-2 terminal-line-row">
                      <input
                        type="text"
                        name={`terminal_line_${loc}_${slide.id}_${lIdx}`}
                        value={line}
                        placeholder="> Línea de output"
                        class="flex-1 bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-xs text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors"
                      />
                      <button
                        type="button"
                        class="text-cyber-red text-sm font-mono hover:text-cyber-red/80 remove-terminal-line-btn"
                        title="Eliminar línea"
                      >
                        &times;
                      </button>
                    </div>
                  ))}
                </div>
                <button
                  type="button"
                  class="mt-2 font-mono text-[10px] text-cyber-teal hover:text-cyber-teal/80 uppercase tracking-widest add-terminal-line-btn"
                  data-slide-id={slide.id}
                  data-locale={loc}
                  data-next-idx={(slide.terminal[loc]?.lines || []).length}
                >
                  + Añadir línea
                </button>
              </div>
            ))}

            {/* ── Buttons ── */}
            <div class="p-4 border border-cyber-border/50 bg-cyber-black/50">
              <div class="font-mono text-[10px] text-cyber-orange uppercase tracking-widest mb-3">
                Botones CTA
              </div>
              <div class="space-y-4 buttons-container" data-slide-id={slide.id}>
                {slide.buttons.map((btn, btnIdx) => (
                  <div class="p-3 border border-cyber-border/30 bg-cyber-dark/50 button-row">
                    <div class="flex items-center justify-between mb-3">
                      <span class="font-mono text-[10px] text-cyber-text uppercase tracking-widest">
                        Botón {btnIdx + 1}
                      </span>
                      <button
                        type="button"
                        class="text-cyber-red text-xs font-mono hover:text-cyber-red/80 remove-button-btn"
                        title="Eliminar botón"
                      >
                        &times; Eliminar
                      </button>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-3">
                      <div>
                        <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">
                          Href / Anchor
                        </label>
                        <input
                          type="text"
                          name={`btn_href_${slide.id}_${btnIdx}`}
                          value={btn.href}
                          placeholder="#seccion"
                          class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors"
                        />
                      </div>
                      <div>
                        <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">
                          Estilo
                        </label>
                        <select
                          name={`btn_style_${slide.id}_${btnIdx}`}
                          class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors"
                        >
                          <option value="primary"   selected={btn.style === 'primary'}>Primary</option>
                          <option value="secondary" selected={btn.style === 'secondary'}>Secondary</option>
                        </select>
                      </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                      {locales.map((loc) => (
                        <div>
                          <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">
                            Label {localeLabels[loc]}
                          </label>
                          <input
                            type="text"
                            name={`btn_label_${loc}_${slide.id}_${btnIdx}`}
                            value={btn.label[loc] || ''}
                            class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors"
                          />
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
              <button
                type="button"
                class="mt-3 font-mono text-[10px] text-cyber-teal hover:text-cyber-teal/80 uppercase tracking-widest add-button-btn"
                data-slide-id={slide.id}
                data-next-idx={slide.buttons.length}
              >
                + Añadir botón
              </button>
            </div>

            {/* ── Microcopy (optional) ── */}
            <div class="p-4 border border-cyber-border/50 bg-cyber-black/50">
              <div class="font-mono text-[10px] text-cyber-orange uppercase tracking-widest mb-1">
                Microcopy (opcional)
              </div>
              <p class="font-mono text-[9px] text-cyber-text/60 mb-3">
                Texto pequeño debajo de los botones. Solo algunos slides lo usan.
              </p>
              <div class="space-y-3">
                {locales.map((loc) => (
                  <div>
                    <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">
                      {localeLabels[loc]} ({loc.toUpperCase()})
                    </label>
                    <textarea
                      name={`microcopy_${loc}_${slide.id}`}
                      rows="2"
                      class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors resize-none"
                    >{slide.microcopy?.[loc] || ''}</textarea>
                  </div>
                ))}
              </div>
            </div>

          </div>{/* end slide-body */}
        </div>
      ))}
    </div>

    {slides.length > 0 && (
      <button type="submit" class="btn-primary text-xs py-3 px-6">
        Guardar todos los slides
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </button>
    )}
  </form>

  {slides.length === 0 && (
    <div class="card-brutal p-8 text-center">
      <p class="text-cyber-text font-mono text-sm">No hay slides. Crea uno para empezar.</p>
    </div>
  )}

  {/* Delete form */}
  <form method="POST" id="delete-form" class="hidden">
    <input type="hidden" name="_action" value="delete" />
    <input type="hidden" name="delete_id" id="delete-id" value="" />
  </form>

  <script>
    // ── Toggle expand/collapse ──────────────────────────────────────────────────
    document.querySelectorAll('.toggle-expand-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = (btn as HTMLElement).dataset.target!;
        const body = document.getElementById(targetId);
        if (!body) return;
        const isHidden = body.classList.contains('hidden');
        body.classList.toggle('hidden', !isHidden);
        btn.textContent = isHidden ? '▾ Cerrar' : '▸ Editar';
      });
    });

    // ── Delete slide ──────────────────────────────────────────────────────────
    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const id   = (btn as HTMLElement).dataset.id!;
        const name = (btn as HTMLElement).dataset.name!;
        if (confirm(`¿Eliminar el slide "${name}"?`)) {
          const form = document.getElementById('delete-form') as HTMLFormElement;
          (document.getElementById('delete-id') as HTMLInputElement).value = id;
          form.submit();
        }
      });
    });

    // ── Drag-and-Drop ─────────────────────────────────────────────────────────
    const container = document.getElementById('slides-container');
    let dragging: HTMLElement | null = null;

    if (container) {
      container.addEventListener('dragstart', (e: DragEvent) => {
        const card = (e.target as HTMLElement).closest('.slide-card') as HTMLElement | null;
        if (!card) return;
        dragging = card;
        setTimeout(() => card.classList.add('opacity-40'), 0);
        e.dataTransfer!.effectAllowed = 'move';
      });

      container.addEventListener('dragend', () => {
        if (dragging) dragging.classList.remove('opacity-40');
        dragging = null;
        // Remove all drag-over highlights
        container.querySelectorAll('.slide-card').forEach(c => {
          c.classList.remove('border-cyber-orange');
        });
      });

      container.addEventListener('dragover', (e: DragEvent) => {
        e.preventDefault();
        e.dataTransfer!.dropEffect = 'move';
        const card = (e.target as HTMLElement).closest('.slide-card') as HTMLElement | null;
        if (!card || card === dragging) return;
        // Highlight target
        container.querySelectorAll('.slide-card').forEach(c => c.classList.remove('border-cyber-orange'));
        card.classList.add('border-cyber-orange');
        // Determine insertion position
        const rect = card.getBoundingClientRect();
        const midY = rect.top + rect.height / 2;
        if (e.clientY < midY) {
          container.insertBefore(dragging!, card);
        } else {
          container.insertBefore(dragging!, card.nextSibling);
        }
      });

      container.addEventListener('drop', (e: DragEvent) => {
        e.preventDefault();
      });
    }

    // ── Remove badge ─────────────────────────────────────────────────────────
    document.addEventListener('click', (e: MouseEvent) => {
      const btn = (e.target as HTMLElement).closest('.remove-badge-btn');
      if (!btn) return;
      const row = btn.closest('.badge-row');
      if (!row) return;
      const cont = row.closest('.badges-container') as HTMLElement;
      row.remove();
      reindexBadges(cont);
    });

    // ── Add badge ─────────────────────────────────────────────────────────────
    document.addEventListener('click', (e: MouseEvent) => {
      const btn = (e.target as HTMLElement).closest('.add-badge-btn') as HTMLElement | null;
      if (!btn) return;
      const slideId = btn.dataset.slideId!;
      const locale  = btn.dataset.locale!;
      const cont    = document.querySelector(`.badges-container[data-slide-id="${slideId}"][data-locale="${locale}"]`);
      if (!cont) return;
      const idx = cont.querySelectorAll('.badge-row').length;
      const row = document.createElement('div');
      row.className = 'flex items-center gap-2 badge-row';
      row.innerHTML = `
        <input type="text" name="badge_${locale}_${slideId}_${idx}" value="" placeholder="BADGE_TEXT"
          class="flex-1 bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-xs text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors" />
        <button type="button" class="text-cyber-red text-sm font-mono hover:text-cyber-red/80 remove-badge-btn" title="Eliminar badge">&times;</button>
      `;
      cont.appendChild(row);
      btn.dataset.nextIdx = String(idx + 1);
    });

    function reindexBadges(cont: HTMLElement) {
      const slideId = cont.dataset.slideId!;
      const locale  = cont.dataset.locale!;
      cont.querySelectorAll('.badge-row input[type="text"]').forEach((inp, i) => {
        (inp as HTMLInputElement).name = `badge_${locale}_${slideId}_${i}`;
      });
    }

    // ── Remove terminal line ──────────────────────────────────────────────────
    document.addEventListener('click', (e: MouseEvent) => {
      const btn = (e.target as HTMLElement).closest('.remove-terminal-line-btn');
      if (!btn) return;
      const row = btn.closest('.terminal-line-row');
      if (!row) return;
      const cont = row.closest('.terminal-lines-container') as HTMLElement;
      row.remove();
      reindexTerminalLines(cont);
    });

    // ── Add terminal line ─────────────────────────────────────────────────────
    document.addEventListener('click', (e: MouseEvent) => {
      const btn = (e.target as HTMLElement).closest('.add-terminal-line-btn') as HTMLElement | null;
      if (!btn) return;
      const slideId = btn.dataset.slideId!;
      const locale  = btn.dataset.locale!;
      const cont    = document.querySelector(`.terminal-lines-container[data-slide-id="${slideId}"][data-locale="${locale}"]`);
      if (!cont) return;
      const idx = cont.querySelectorAll('.terminal-line-row').length;
      const row = document.createElement('div');
      row.className = 'flex items-center gap-2 terminal-line-row';
      row.innerHTML = `
        <input type="text" name="terminal_line_${locale}_${slideId}_${idx}" value="" placeholder="> Línea de output"
          class="flex-1 bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-xs text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors" />
        <button type="button" class="text-cyber-red text-sm font-mono hover:text-cyber-red/80 remove-terminal-line-btn" title="Eliminar línea">&times;</button>
      `;
      cont.appendChild(row);
      btn.dataset.nextIdx = String(idx + 1);
    });

    function reindexTerminalLines(cont: HTMLElement) {
      const slideId = cont.dataset.slideId!;
      const locale  = cont.dataset.locale!;
      cont.querySelectorAll('.terminal-line-row input[type="text"]').forEach((inp, i) => {
        (inp as HTMLInputElement).name = `terminal_line_${locale}_${slideId}_${i}`;
      });
    }

    // ── Remove button ─────────────────────────────────────────────────────────
    document.addEventListener('click', (e: MouseEvent) => {
      const btn = (e.target as HTMLElement).closest('.remove-button-btn');
      if (!btn) return;
      const row = btn.closest('.button-row');
      if (!row) return;
      const cont = row.closest('.buttons-container') as HTMLElement;
      row.remove();
      reindexButtons(cont);
    });

    // ── Add button ────────────────────────────────────────────────────────────
    document.addEventListener('click', (e: MouseEvent) => {
      const btn = (e.target as HTMLElement).closest('.add-button-btn') as HTMLElement | null;
      if (!btn) return;
      const slideId = btn.dataset.slideId!;
      const cont    = document.querySelector(`.buttons-container[data-slide-id="${slideId}"]`);
      if (!cont) return;
      const idx = cont.querySelectorAll('.button-row').length;
      const row = document.createElement('div');
      row.className = 'p-3 border border-cyber-border/30 bg-cyber-dark/50 button-row';
      row.innerHTML = `
        <div class="flex items-center justify-between mb-3">
          <span class="font-mono text-[10px] text-cyber-text uppercase tracking-widest">Botón ${idx + 1}</span>
          <button type="button" class="text-cyber-red text-xs font-mono hover:text-cyber-red/80 remove-button-btn" title="Eliminar botón">&times; Eliminar</button>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-3">
          <div>
            <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Href / Anchor</label>
            <input type="text" name="btn_href_${slideId}_${idx}" value="" placeholder="#seccion"
              class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Estilo</label>
            <select name="btn_style_${slideId}_${idx}"
              class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors">
              <option value="primary">Primary</option>
              <option value="secondary">Secondary</option>
            </select>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div>
            <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Label Castellano</label>
            <input type="text" name="btn_label_es_${slideId}_${idx}" value=""
              class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Label Català</label>
            <input type="text" name="btn_label_ca_${slideId}_${idx}" value=""
              class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors" />
          </div>
        </div>
      `;
      cont.appendChild(row);
      btn.dataset.nextIdx = String(idx + 1);
    });

    function reindexButtons(cont: HTMLElement) {
      const slideId = cont.dataset.slideId!;
      cont.querySelectorAll('.button-row').forEach((row, i) => {
        (row.querySelector('input[name^="btn_href_"]') as HTMLInputElement | null)
          && ((row.querySelector('input[name^="btn_href_"]') as HTMLInputElement).name = `btn_href_${slideId}_${i}`);
        (row.querySelector('select[name^="btn_style_"]') as HTMLSelectElement | null)
          && ((row.querySelector('select[name^="btn_style_"]') as HTMLSelectElement).name = `btn_style_${slideId}_${i}`);
        (row.querySelector('input[name^="btn_label_es_"]') as HTMLInputElement | null)
          && ((row.querySelector('input[name^="btn_label_es_"]') as HTMLInputElement).name = `btn_label_es_${slideId}_${i}`);
        (row.querySelector('input[name^="btn_label_ca_"]') as HTMLInputElement | null)
          && ((row.querySelector('input[name^="btn_label_ca_"]') as HTMLInputElement).name = `btn_label_ca_${slideId}_${i}`);
        const label = row.querySelector('span.font-mono');
        if (label) label.textContent = `Botón ${i + 1}`;
      });
    }
  </script>
</AdminLayout>
