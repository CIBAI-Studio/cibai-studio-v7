---
import AdminLayout from '../../layouts/AdminLayout.astro';
import '../../styles/global.css';
import { getAuthUser } from '../../lib/auth';
import { loadSettings, saveSettings, generateStepId, type ProcessStep } from '../../lib/settings';
import { locales, getLocaleLabels } from '../../i18n';

const user = getAuthUser(Astro.cookies);
if (!user) return Astro.redirect('/admin/login');

const settings = loadSettings();
let successMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('_action') as string;

  if (action === 'save_all') {
    const stepIds = formData.getAll('step_id') as string[];
    const updatedSteps: ProcessStep[] = [];

    for (let i = 0; i < stepIds.length; i++) {
      const id = stepIds[i];
      const existing = settings.processSteps.find(s => s.id === id);
      if (!existing) continue;

      const imageUrl = (formData.get(`image_${id}`) as string || '').trim();
      const active = formData.has(`active_${id}`);

      const step: ProcessStep = {
        id,
        num: (formData.get(`num_${id}`) as string) || existing.num,
        active,
        order: i,
        ...(imageUrl ? { image: imageUrl } : {}),
        title: {} as Record<string, string>,
        description: {} as Record<string, string>,
      };

      for (const loc of locales) {
        step.title[loc] = (formData.get(`title_${loc}_${id}`) as string) || '';
        step.description[loc] = (formData.get(`desc_${loc}_${id}`) as string) || '';
      }

      updatedSteps.push(step);
    }

    settings.processSteps = updatedSteps;
    saveSettings(settings);
    successMessage = 'Pasos del proceso guardados correctamente.';
  }

  if (action === 'create') {
    const maxOrder = settings.processSteps.reduce((m, s) => Math.max(m, s.order), -1);
    const newStep: ProcessStep = {
      id: generateStepId(),
      num: String(settings.processSteps.length + 1).padStart(2, '0'),
      active: true,
      order: maxOrder + 1,
      title: { es: 'NUEVO PASO', ca: 'NOU PAS' },
      description: { es: 'Descripción del paso.', ca: 'Descripció del pas.' },
    };
    settings.processSteps.push(newStep);
    saveSettings(settings);
    successMessage = 'Paso creado. Edítalo a continuación.';
  }

  if (action === 'delete') {
    const deleteId = formData.get('delete_id') as string;
    settings.processSteps = settings.processSteps.filter(s => s.id !== deleteId);
    saveSettings(settings);
    successMessage = 'Paso eliminado.';
  }
}

const localeLabels = getLocaleLabels();
const steps = [...settings.processSteps].sort((a, b) => a.order - b.order);
---

<AdminLayout title="Proceso" userName={user.name}>
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-black tracking-tight mb-2">Proceso / Método</h1>
      <p class="text-sm text-cyber-text">Gestiona los pasos del proceso que se muestran en la sección &ldquo;Así trabajamos&rdquo;.</p>
    </div>
    <form method="POST">
      <input type="hidden" name="_action" value="create" />
      <button type="submit" class="btn-primary text-xs py-2 px-5">+ Nuevo paso</button>
    </form>
  </div>

  {successMessage && (
    <div class="mb-6 px-4 py-3 border border-cyber-teal/30 bg-cyber-teal/5 text-cyber-teal font-mono text-xs">
      {successMessage}
    </div>
  )}

  <form method="POST">
    <input type="hidden" name="_action" value="save_all" />

    <div id="steps-list" class="space-y-6">
      {steps.map((step, stepIdx) => (
        <div
          class={`card-brutal p-6 step-card transition-opacity duration-200 ${step.active ? '' : 'opacity-40'}`}
          draggable="true"
          data-id={step.id}
          data-order={step.order}
          id={`card-${step.id}`}
        >
          <input type="hidden" name="step_id" value={step.id} />
          <input type="hidden" name={`order_${step.id}`} value={stepIdx} class="order-input" />

          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
              <span class="drag-handle cursor-grab active:cursor-grabbing text-cyber-text/40 hover:text-cyber-text/80 transition-colors select-none text-lg leading-none" title="Arrastrar para reordenar">
                ⠿
              </span>
              <h2 class="font-mono text-sm font-bold text-cyber-white">
                <span class="text-cyber-orange">{step.num}</span> — {step.title.es}
              </h2>
            </div>

            <div class="flex items-center gap-4">
              <label class="flex items-center gap-2 cursor-pointer select-none" title="Activo/Inactivo">
                <input
                  type="checkbox"
                  name={`active_${step.id}`}
                  checked={step.active}
                  class="active-toggle sr-only"
                  data-card={`card-${step.id}`}
                />
                <span class={`relative inline-flex h-5 w-9 items-center rounded-full border transition-colors duration-200 ${step.active ? 'bg-cyber-teal/20 border-cyber-teal' : 'bg-cyber-black border-cyber-border'}`} style="flex-shrink:0;">
                  <span class={`inline-block h-3 w-3 rounded-full transition-transform duration-200 ${step.active ? 'translate-x-4 bg-cyber-teal' : 'translate-x-1 bg-cyber-text/40'}`}></span>
                </span>
                <span class="font-mono text-[10px] text-cyber-text uppercase tracking-widest">{step.active ? 'Activo' : 'Inactivo'}</span>
              </label>

              <button type="button" class="font-mono text-[10px] text-cyber-red hover:text-cyber-red/80 uppercase tracking-widest transition-colors delete-btn" data-id={step.id} data-name={step.title.es}>Eliminar</button>
            </div>
          </div>

          {/* Basic Fields */}
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
            <div>
              <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Número</label>
              <input type="text" name={`num_${step.id}`} value={step.num} class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors" />
            </div>
          </div>

          {/* Step Image */}
          <div class="mb-6 p-4 border border-cyber-border/50 bg-cyber-black/50">
            <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-2">Imagen</label>
            <div class="flex items-end gap-4">
              <div class="flex-1">
                <input type="text" name={`image_${step.id}`} value={step.image || ''} id={`image-input-${step.id}`} placeholder="URL de imagen o genera con IA" class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white placeholder:text-cyber-text/30 focus:border-cyber-orange focus:outline-none transition-colors" />
              </div>
              <button type="button" class="generate-image-btn btn-secondary text-[10px] py-2 px-4 whitespace-nowrap" data-target={`image-input-${step.id}`} data-prompt={`${step.title.es}, business process step, professional`}>
                Generar con IA
              </button>
            </div>
            {step.image && (
              <div class="mt-3">
                <img src={step.image} alt="Preview" class="max-h-28 border border-cyber-border" />
              </div>
            )}
          </div>

          {/* Translations per locale */}
          {locales.map((loc) => (
            <div class="mb-6 p-4 border border-cyber-border/50 bg-cyber-black/50">
              <div class="font-mono text-[10px] text-cyber-orange uppercase tracking-widest mb-3">{localeLabels[loc]} ({loc.toUpperCase()})</div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-3">
                <div>
                  <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Título</label>
                  <input type="text" name={`title_${loc}_${step.id}`} value={step.title[loc] || ''} class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors" />
                </div>
              </div>
              <div>
                <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Descripción</label>
                <textarea name={`desc_${loc}_${step.id}`} rows="3" class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors resize-none">{step.description[loc] || ''}</textarea>
              </div>
            </div>
          ))}
        </div>
      ))}
    </div>

    {steps.length > 0 && (
      <div class="mt-6">
        <button type="submit" class="btn-primary text-xs py-3 px-6">
          Guardar todos los pasos
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        </button>
      </div>
    )}
  </form>

  {steps.length === 0 && (
    <div class="card-brutal p-8 text-center">
      <p class="text-cyber-text font-mono text-sm">No hay pasos. Crea uno para empezar.</p>
    </div>
  )}

  <form method="POST" id="delete-form" class="hidden">
    <input type="hidden" name="_action" value="delete" />
    <input type="hidden" name="delete_id" id="delete-id" value="" />
  </form>

  <script>
    // ── Delete step ──────────────────────────────────────────────────────────
    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.id;
        const name = (btn as HTMLElement).dataset.name;
        if (confirm(`¿Eliminar el paso "${name}"?`)) {
          const form = document.getElementById('delete-form') as HTMLFormElement;
          (document.getElementById('delete-id') as HTMLInputElement).value = id || '';
          form.submit();
        }
      });
    });

    // ── Active toggle visual feedback ───────────────────────────────────────────
    document.querySelectorAll('.active-toggle').forEach(checkbox => {
      checkbox.addEventListener('change', () => {
        const cb = checkbox as HTMLInputElement;
        const cardId = cb.dataset.card;
        const card = document.getElementById(cardId || '');
        if (!card) return;

        if (cb.checked) {
          card.classList.remove('opacity-40');
        } else {
          card.classList.add('opacity-40');
        }

        const label = cb.closest('label');
        if (!label) return;
        const track = label.querySelector('span:nth-child(2)') as HTMLElement;
        const thumb = label.querySelector('span:nth-child(2) > span') as HTMLElement;
        const text = label.querySelector('span:nth-child(3)') as HTMLElement;

        if (cb.checked) {
          track.className = 'relative inline-flex h-5 w-9 items-center rounded-full border transition-colors duration-200 bg-cyber-teal/20 border-cyber-teal';
          thumb.className = 'inline-block h-3 w-3 rounded-full transition-transform duration-200 translate-x-4 bg-cyber-teal';
          if (text) text.textContent = 'Activo';
        } else {
          track.className = 'relative inline-flex h-5 w-9 items-center rounded-full border transition-colors duration-200 bg-cyber-black border-cyber-border';
          thumb.className = 'inline-block h-3 w-3 rounded-full transition-transform duration-200 translate-x-1 bg-cyber-text/40';
          if (text) text.textContent = 'Inactivo';
        }
      });
    });

    // ── Drag-and-drop reordering ────────────────────────────────────────────────
    const list = document.getElementById('steps-list');
    if (list) {
      let dragSrc: HTMLElement | null = null;

      function updateOrderInputs() {
        list!.querySelectorAll('.step-card').forEach((card, idx) => {
          const input = card.querySelector('.order-input') as HTMLInputElement;
          if (input) input.value = String(idx);
        });
      }

      list.addEventListener('dragstart', (e) => {
        const target = (e.target as HTMLElement).closest('.step-card') as HTMLElement;
        if (!target) return;
        dragSrc = target;
        target.classList.add('opacity-50', 'ring-2', 'ring-cyber-orange');
        e.dataTransfer!.effectAllowed = 'move';
        e.dataTransfer!.setData('text/plain', target.dataset.id || '');
      });

      list.addEventListener('dragend', (e) => {
        const target = (e.target as HTMLElement).closest('.step-card') as HTMLElement;
        if (target) {
          target.classList.remove('opacity-50', 'ring-2', 'ring-cyber-orange');
        }
        list.querySelectorAll('.step-card').forEach(card => {
          card.classList.remove('drag-over');
        });
        dragSrc = null;
      });

      list.addEventListener('dragover', (e) => {
        e.preventDefault();
        e.dataTransfer!.dropEffect = 'move';
        const target = (e.target as HTMLElement).closest('.step-card') as HTMLElement;
        if (!target || target === dragSrc) return;

        list.querySelectorAll('.step-card').forEach(card => {
          card.classList.remove('drag-over');
        });
        target.classList.add('drag-over');
      });

      list.addEventListener('dragleave', (e) => {
        const target = (e.target as HTMLElement).closest('.step-card') as HTMLElement;
        if (target) target.classList.remove('drag-over');
      });

      list.addEventListener('drop', (e) => {
        e.preventDefault();
        const target = (e.target as HTMLElement).closest('.step-card') as HTMLElement;
        if (!target || !dragSrc || target === dragSrc) return;

        target.classList.remove('drag-over');

        const rect = target.getBoundingClientRect();
        const midY = rect.top + rect.height / 2;
        const insertBefore = e.clientY < midY;

        if (insertBefore) {
          list.insertBefore(dragSrc, target);
        } else {
          list.insertBefore(dragSrc, target.nextSibling);
        }

        updateOrderInputs();
      });
    }

    // ── Generate image with fal.ai ─────────────────────────────────────────────
    document.querySelectorAll('.generate-image-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const el = btn as HTMLElement;
        const targetId = el.dataset.target;
        const prompt = el.dataset.prompt || 'futuristic technology';
        const input = document.getElementById(targetId || '') as HTMLInputElement;
        if (!input) return;

        el.textContent = 'Generando...';
        el.setAttribute('disabled', 'true');
        el.classList.add('opacity-50');

        try {
          const res = await fetch('/api/generate-image', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prompt, width: 768, height: 512 }),
          });
          const data = await res.json();
          if (data.url) {
            input.value = data.url;
            const container = input.closest('.p-4');
            let preview = container?.querySelector('img');
            if (preview) {
              preview.src = data.url;
            } else if (container) {
              const div = document.createElement('div');
              div.className = 'mt-3';
              div.innerHTML = `<img src="${data.url}" alt="Preview" class="max-h-28 border border-cyber-border" />`;
              container.appendChild(div);
            }
          } else {
            alert('Error generando imagen: ' + (data.error || 'Unknown error'));
          }
        } catch (err: any) {
          alert('Error: ' + err.message);
        } finally {
          el.textContent = 'Generar con IA';
          el.removeAttribute('disabled');
          el.classList.remove('opacity-50');
        }
      });
    });
  </script>

  <style>
    .drag-over {
      border-color: #FF4D00 !important;
      box-shadow: 0 0 0 2px #FF4D0044;
    }
    .drag-handle {
      font-size: 1.25rem;
      line-height: 1;
      user-select: none;
    }
  </style>
</AdminLayout>
