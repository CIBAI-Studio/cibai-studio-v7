---
import AdminLayout from '../../layouts/AdminLayout.astro';
import '../../styles/global.css';
import { getAuthUser } from '../../lib/auth';
import { loadSettings, saveSettings, generateId, type ServiceItem, type ServiceTag } from '../../lib/settings';
import { locales, getLocaleLabels } from '../../i18n';

const user = getAuthUser(Astro.cookies);
if (!user) return Astro.redirect('/admin/login');

const settings = loadSettings();
let successMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('_action') as string;

  if (action === 'save_all') {
    const serviceIds = formData.getAll('service_id') as string[];
    const updatedServices: ServiceItem[] = [];

    for (const id of serviceIds) {
      const existing = settings.services.find(s => s.id === id);
      if (!existing) continue;

      // Parse tags: tag_text_<id>_<idx> and tag_color_<id>_<idx>
      const tags: ServiceTag[] = [];
      let tagIdx = 0;
      while (formData.has(`tag_text_${id}_${tagIdx}`)) {
        const text = (formData.get(`tag_text_${id}_${tagIdx}`) as string || '').trim();
        const borderColor = (formData.get(`tag_color_${id}_${tagIdx}`) as string || '#2a2a2a').trim();
        if (text) tags.push({ text, borderColor });
        tagIdx++;
      }

      // Read order and active
      const orderVal = formData.get(`order_${id}`);
      const order = orderVal !== null ? parseInt(orderVal as string, 10) : existing.order;
      const active = formData.has(`active_${id}`);

      const svc: ServiceItem = {
        id,
        num: (formData.get(`num_${id}`) as string) || existing.num,
        active,
        order,
        label: {} as Record<string, string>,
        title: {} as Record<string, string>,
        description: {} as Record<string, string>,
        tags,
        colors: {
          numColor: (formData.get(`color_num_${id}`) as string) || existing.colors.numColor,
          labelColor: (formData.get(`color_label_${id}`) as string) || existing.colors.labelColor,
          titleColor: (formData.get(`color_title_${id}`) as string) || existing.colors.titleColor,
          descriptionColor: (formData.get(`color_desc_${id}`) as string) || existing.colors.descriptionColor,
          hoverBorderColor: (formData.get(`color_hover_${id}`) as string) || existing.colors.hoverBorderColor,
        },
      };

      for (const loc of locales) {
        svc.label[loc] = (formData.get(`label_${loc}_${id}`) as string) || '';
        svc.title[loc] = (formData.get(`title_${loc}_${id}`) as string) || '';
        svc.description[loc] = (formData.get(`desc_${loc}_${id}`) as string) || '';
      }

      updatedServices.push(svc);
    }

    // Sort by order before saving
    updatedServices.sort((a, b) => a.order - b.order);
    settings.services = updatedServices;
    saveSettings(settings);
    successMessage = 'Servicios guardados correctamente.';
  }

  if (action === 'create') {
    const maxOrder = settings.services.reduce((m, s) => Math.max(m, s.order), -1);
    const newSvc: ServiceItem = {
      id: generateId(),
      num: String(settings.services.length + 1).padStart(2, '0'),
      active: true,
      order: maxOrder + 1,
      label: { es: 'NUEVO_SERVICIO', ca: 'NOU_SERVEI' },
      title: { es: 'Nuevo Servicio', ca: 'Nou Servei' },
      description: { es: 'Descripción del servicio.', ca: 'Descripció del servei.' },
      tags: [
        { text: 'TAG1', borderColor: '#2a2a2a' },
        { text: 'TAG2', borderColor: '#2a2a2a' },
      ],
      colors: {
        numColor: '#FFFFFF12',
        labelColor: settings.visual.secondaryColor,
        titleColor: '#F5F5F5',
        descriptionColor: '#888888',
        hoverBorderColor: settings.visual.primaryColor,
      },
    };
    settings.services.push(newSvc);
    saveSettings(settings);
    successMessage = 'Servicio creado. Edítalo a continuación.';
  }

  if (action === 'delete') {
    const deleteId = formData.get('delete_id') as string;
    settings.services = settings.services.filter(s => s.id !== deleteId);
    saveSettings(settings);
    successMessage = 'Servicio eliminado.';
  }
}

const localeLabels = getLocaleLabels();
// Sort services by order for display
const services = [...settings.services].sort((a, b) => a.order - b.order);
---

<AdminLayout title="Servicios" userName={user.name}>
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-black tracking-tight mb-2">Servicios</h1>
      <p class="text-sm text-cyber-text">Gestiona los servicios que se muestran en el frontend. Arrastra para reordenar. Cada servicio se traduce a todos los idiomas.</p>
    </div>
    <form method="POST">
      <input type="hidden" name="_action" value="create" />
      <button type="submit" class="btn-primary text-xs py-2 px-5">+ Nuevo servicio</button>
    </form>
  </div>

  {successMessage && (
    <div class="mb-6 px-4 py-3 border border-cyber-teal/30 bg-cyber-teal/5 text-cyber-teal font-mono text-xs">
      {successMessage}
    </div>
  )}

  <form method="POST">
    <input type="hidden" name="_action" value="save_all" />

    <div id="services-list" class="space-y-6">
      {services.map((svc, svcIdx) => (
        <div
          class={`card-brutal p-6 service-card transition-opacity duration-200 ${svc.active ? '' : 'opacity-40'}`}
          draggable="true"
          data-id={svc.id}
          data-order={svc.order}
          id={`card-${svc.id}`}
        >
          <input type="hidden" name="service_id" value={svc.id} />
          <input type="hidden" name={`order_${svc.id}`} value={svcIdx} class="order-input" />

          <div class="flex items-center justify-between mb-6">
            {/* Grip handle */}
            <div class="flex items-center gap-3">
              <span class="drag-handle cursor-grab active:cursor-grabbing text-cyber-text/40 hover:text-cyber-text/80 transition-colors select-none text-lg leading-none" title="Arrastrar para reordenar">
                ⠿
              </span>
              <h2 class="font-mono text-sm font-bold text-cyber-white">
                <span class="text-cyber-orange">{svc.num}</span> — {svc.title.es}
              </h2>
            </div>

            <div class="flex items-center gap-4">
              {/* Toggle activo */}
              <label class="flex items-center gap-2 cursor-pointer select-none" title="Activo/Inactivo">
                <input
                  type="checkbox"
                  name={`active_${svc.id}`}
                  checked={svc.active}
                  class="active-toggle sr-only"
                  data-card={`card-${svc.id}`}
                />
                <span class={`relative inline-flex h-5 w-9 items-center rounded-full border transition-colors duration-200 ${svc.active ? 'bg-cyber-teal/20 border-cyber-teal' : 'bg-cyber-black border-cyber-border'}`} style="flex-shrink:0;">
                  <span class={`inline-block h-3 w-3 rounded-full transition-transform duration-200 ${svc.active ? 'translate-x-4 bg-cyber-teal' : 'translate-x-1 bg-cyber-text/40'}`}></span>
                </span>
                <span class="font-mono text-[10px] text-cyber-text uppercase tracking-widest">{svc.active ? 'Activo' : 'Inactivo'}</span>
              </label>

              <button type="button" class="font-mono text-[10px] text-cyber-red hover:text-cyber-red/80 uppercase tracking-widest transition-colors delete-btn" data-id={svc.id} data-name={svc.title.es}>Eliminar</button>
            </div>
          </div>

          {/* Basic Fields */}
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
            <div>
              <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Número</label>
              <input type="text" name={`num_${svc.id}`} value={svc.num} class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors" />
            </div>
          </div>

          {/* Translations per locale */}
          {locales.map((loc) => (
            <div class="mb-6 p-4 border border-cyber-border/50 bg-cyber-black/50">
              <div class="font-mono text-[10px] text-cyber-orange uppercase tracking-widest mb-3">{localeLabels[loc]} ({loc.toUpperCase()})</div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-3">
                <div>
                  <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Label</label>
                  <input type="text" name={`label_${loc}_${svc.id}`} value={svc.label[loc] || ''} class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors" />
                </div>
                <div>
                  <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Título</label>
                  <input type="text" name={`title_${loc}_${svc.id}`} value={svc.title[loc] || ''} class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors" />
                </div>
              </div>
              <div>
                <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Descripción</label>
                <textarea name={`desc_${loc}_${svc.id}`} rows="3" class="w-full bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors resize-none">{svc.description[loc] || ''}</textarea>
              </div>
            </div>
          ))}

          {/* Tags with individual border colors */}
          <div class="mb-6">
            <div class="font-mono text-[10px] text-cyber-text uppercase tracking-widest mb-3">Tags / Tecnologías</div>
            <div class="space-y-2 tags-container" data-svc-id={svc.id}>
              {svc.tags.map((tag, tIdx) => (
                <div class="flex items-center gap-3 tag-row">
                  <input type="text" name={`tag_text_${svc.id}_${tIdx}`} value={tag.text} placeholder="TAG" class="flex-1 bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-xs text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors" />
                  <div class="flex items-center gap-1">
                    <label class="font-mono text-[9px] text-cyber-text/50">Borde:</label>
                    <input type="color" value={tag.borderColor} class="w-7 h-7 border border-cyber-border bg-cyber-black cursor-pointer" oninput={`this.nextElementSibling.value=this.value`} />
                    <input type="text" name={`tag_color_${svc.id}_${tIdx}`} value={tag.borderColor} class="w-20 bg-cyber-black border border-cyber-border px-2 py-1 font-mono text-[10px] text-cyber-white focus:border-cyber-orange focus:outline-none" />
                  </div>
                  <button type="button" class="text-cyber-red text-xs font-mono hover:text-cyber-red/80 remove-tag-btn" title="Eliminar tag">&times;</button>
                </div>
              ))}
            </div>
            <button type="button" class="mt-2 font-mono text-[10px] text-cyber-teal hover:text-cyber-teal/80 uppercase tracking-widest add-tag-btn" data-svc-id={svc.id} data-next-idx={svc.tags.length}>
              + Añadir tag
            </button>
          </div>

          {/* Colors */}
          <details class="group">
            <summary class="font-mono text-[10px] text-cyber-text uppercase tracking-widest cursor-pointer hover:text-cyber-white transition-colors mb-4">
              &#x25B8; Colores personalizados
            </summary>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4 pt-2">
              <div>
                <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Color número</label>
                <div class="flex items-center gap-2">
                  <input type="color" value={svc.colors.numColor.length === 7 ? svc.colors.numColor : '#FFFFFF'} class="w-8 h-8 border border-cyber-border bg-cyber-black cursor-pointer" oninput={`this.nextElementSibling.value=this.value`} />
                  <input type="text" name={`color_num_${svc.id}`} value={svc.colors.numColor} class="flex-1 bg-cyber-black border border-cyber-border px-2 py-1 font-mono text-xs text-cyber-white focus:border-cyber-orange focus:outline-none" />
                </div>
              </div>
              <div>
                <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Color label</label>
                <div class="flex items-center gap-2">
                  <input type="color" value={svc.colors.labelColor} class="w-8 h-8 border border-cyber-border bg-cyber-black cursor-pointer" oninput={`this.nextElementSibling.value=this.value`} />
                  <input type="text" name={`color_label_${svc.id}`} value={svc.colors.labelColor} class="flex-1 bg-cyber-black border border-cyber-border px-2 py-1 font-mono text-xs text-cyber-white focus:border-cyber-orange focus:outline-none" />
                </div>
              </div>
              <div>
                <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Color título</label>
                <div class="flex items-center gap-2">
                  <input type="color" value={svc.colors.titleColor} class="w-8 h-8 border border-cyber-border bg-cyber-black cursor-pointer" oninput={`this.nextElementSibling.value=this.value`} />
                  <input type="text" name={`color_title_${svc.id}`} value={svc.colors.titleColor} class="flex-1 bg-cyber-black border border-cyber-border px-2 py-1 font-mono text-xs text-cyber-white focus:border-cyber-orange focus:outline-none" />
                </div>
              </div>
              <div>
                <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Color descripción</label>
                <div class="flex items-center gap-2">
                  <input type="color" value={svc.colors.descriptionColor} class="w-8 h-8 border border-cyber-border bg-cyber-black cursor-pointer" oninput={`this.nextElementSibling.value=this.value`} />
                  <input type="text" name={`color_desc_${svc.id}`} value={svc.colors.descriptionColor} class="flex-1 bg-cyber-black border border-cyber-border px-2 py-1 font-mono text-xs text-cyber-white focus:border-cyber-orange focus:outline-none" />
                </div>
              </div>
              <div>
                <label class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-1">Color borde hover</label>
                <div class="flex items-center gap-2">
                  <input type="color" value={svc.colors.hoverBorderColor} class="w-8 h-8 border border-cyber-border bg-cyber-black cursor-pointer" oninput={`this.nextElementSibling.value=this.value`} />
                  <input type="text" name={`color_hover_${svc.id}`} value={svc.colors.hoverBorderColor} class="flex-1 bg-cyber-black border border-cyber-border px-2 py-1 font-mono text-xs text-cyber-white focus:border-cyber-orange focus:outline-none" />
                </div>
              </div>
            </div>
          </details>
        </div>
      ))}
    </div>

    {services.length > 0 && (
      <div class="mt-6">
        <button type="submit" class="btn-primary text-xs py-3 px-6">
          Guardar todos los servicios
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        </button>
      </div>
    )}
  </form>

  {services.length === 0 && (
    <div class="card-brutal p-8 text-center">
      <p class="text-cyber-text font-mono text-sm">No hay servicios. Crea uno para empezar.</p>
    </div>
  )}

  <form method="POST" id="delete-form" class="hidden">
    <input type="hidden" name="_action" value="delete" />
    <input type="hidden" name="delete_id" id="delete-id" value="" />
  </form>

  <script>
    // ── Delete service ──────────────────────────────────────────────────────────
    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.id;
        const name = (btn as HTMLElement).dataset.name;
        if (confirm(`¿Eliminar el servicio "${name}"?`)) {
          const form = document.getElementById('delete-form') as HTMLFormElement;
          (document.getElementById('delete-id') as HTMLInputElement).value = id || '';
          form.submit();
        }
      });
    });

    // ── Remove tag ──────────────────────────────────────────────────────────────
    document.querySelectorAll('.remove-tag-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const row = btn.closest('.tag-row');
        if (row) row.remove();
        // Re-index remaining tags
        document.querySelectorAll('.tags-container').forEach(container => {
          const svcId = (container as HTMLElement).dataset.svcId;
          container.querySelectorAll('.tag-row').forEach((r, i) => {
            const textInput = r.querySelector('input[type="text"]') as HTMLInputElement;
            const colorInput = r.querySelectorAll('input[type="text"]')[1] as HTMLInputElement;
            if (textInput) textInput.name = `tag_text_${svcId}_${i}`;
            if (colorInput) colorInput.name = `tag_color_${svcId}_${i}`;
          });
        });
      });
    });

    // ── Add tag ─────────────────────────────────────────────────────────────────
    document.querySelectorAll('.add-tag-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const svcId = (btn as HTMLElement).dataset.svcId;
        const container = document.querySelector(`.tags-container[data-svc-id="${svcId}"]`);
        if (!container) return;
        const idx = container.querySelectorAll('.tag-row').length;
        const row = document.createElement('div');
        row.className = 'flex items-center gap-3 tag-row';
        row.innerHTML = `
          <input type="text" name="tag_text_${svcId}_${idx}" value="" placeholder="TAG" class="flex-1 bg-cyber-black border border-cyber-border px-3 py-2 font-mono text-xs text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors" />
          <div class="flex items-center gap-1">
            <label class="font-mono text-[9px] text-cyber-text/50">Borde:</label>
            <input type="color" value="#2a2a2a" class="w-7 h-7 border border-cyber-border bg-cyber-black cursor-pointer" oninput="this.nextElementSibling.value=this.value" />
            <input type="text" name="tag_color_${svcId}_${idx}" value="#2a2a2a" class="w-20 bg-cyber-black border border-cyber-border px-2 py-1 font-mono text-[10px] text-cyber-white focus:border-cyber-orange focus:outline-none" />
          </div>
          <button type="button" class="text-cyber-red text-xs font-mono hover:text-cyber-red/80" onclick="this.closest('.tag-row').remove()" title="Eliminar tag">&times;</button>
        `;
        container.appendChild(row);
      });
    });

    // ── Active toggle visual feedback ───────────────────────────────────────────
    document.querySelectorAll('.active-toggle').forEach(checkbox => {
      checkbox.addEventListener('change', () => {
        const cb = checkbox as HTMLInputElement;
        const cardId = cb.dataset.card;
        const card = document.getElementById(cardId || '');
        if (!card) return;

        // Update card opacity
        if (cb.checked) {
          card.classList.remove('opacity-40');
        } else {
          card.classList.add('opacity-40');
        }

        // Update toggle visual (the span elements)
        const label = cb.closest('label');
        if (!label) return;
        const track = label.querySelector('span:nth-child(2)') as HTMLElement;
        const thumb = label.querySelector('span:nth-child(2) > span') as HTMLElement;
        const text = label.querySelector('span:nth-child(3)') as HTMLElement;

        if (cb.checked) {
          track.className = 'relative inline-flex h-5 w-9 items-center rounded-full border transition-colors duration-200 bg-cyber-teal/20 border-cyber-teal';
          thumb.className = 'inline-block h-3 w-3 rounded-full transition-transform duration-200 translate-x-4 bg-cyber-teal';
          if (text) text.textContent = 'Activo';
        } else {
          track.className = 'relative inline-flex h-5 w-9 items-center rounded-full border transition-colors duration-200 bg-cyber-black border-cyber-border';
          thumb.className = 'inline-block h-3 w-3 rounded-full transition-transform duration-200 translate-x-1 bg-cyber-text/40';
          if (text) text.textContent = 'Inactivo';
        }
      });
    });

    // ── Drag-and-drop reordering ────────────────────────────────────────────────
    const list = document.getElementById('services-list');
    if (list) {
      let dragSrc: HTMLElement | null = null;

      function updateOrderInputs() {
        list!.querySelectorAll('.service-card').forEach((card, idx) => {
          const id = (card as HTMLElement).dataset.id;
          if (!id) return;
          const input = card.querySelector('.order-input') as HTMLInputElement;
          if (input) input.value = String(idx);
        });
      }

      list.addEventListener('dragstart', (e) => {
        const target = (e.target as HTMLElement).closest('.service-card') as HTMLElement;
        if (!target) return;
        dragSrc = target;
        target.classList.add('opacity-50', 'ring-2', 'ring-cyber-orange');
        e.dataTransfer!.effectAllowed = 'move';
        e.dataTransfer!.setData('text/plain', target.dataset.id || '');
      });

      list.addEventListener('dragend', (e) => {
        const target = (e.target as HTMLElement).closest('.service-card') as HTMLElement;
        if (target) {
          target.classList.remove('opacity-50', 'ring-2', 'ring-cyber-orange');
        }
        list.querySelectorAll('.service-card').forEach(card => {
          card.classList.remove('drag-over');
        });
        dragSrc = null;
      });

      list.addEventListener('dragover', (e) => {
        e.preventDefault();
        e.dataTransfer!.dropEffect = 'move';
        const target = (e.target as HTMLElement).closest('.service-card') as HTMLElement;
        if (!target || target === dragSrc) return;

        list.querySelectorAll('.service-card').forEach(card => {
          card.classList.remove('drag-over');
        });
        target.classList.add('drag-over');
      });

      list.addEventListener('dragleave', (e) => {
        const target = (e.target as HTMLElement).closest('.service-card') as HTMLElement;
        if (target) target.classList.remove('drag-over');
      });

      list.addEventListener('drop', (e) => {
        e.preventDefault();
        const target = (e.target as HTMLElement).closest('.service-card') as HTMLElement;
        if (!target || !dragSrc || target === dragSrc) return;

        target.classList.remove('drag-over');

        // Determine relative position
        const rect = target.getBoundingClientRect();
        const midY = rect.top + rect.height / 2;
        const insertBefore = e.clientY < midY;

        if (insertBefore) {
          list.insertBefore(dragSrc, target);
        } else {
          list.insertBefore(dragSrc, target.nextSibling);
        }

        updateOrderInputs();
      });
    }
  </script>

  <style>
    .drag-over {
      border-color: #FF4D00 !important;
      box-shadow: 0 0 0 2px #FF4D0044;
    }
    .drag-handle {
      font-size: 1.25rem;
      line-height: 1;
      user-select: none;
    }
  </style>
</AdminLayout>
