---
import type { Locale } from '../i18n';
import { getTranslations, getLocalizedPath } from '../i18n';
import LanguageSelector from './LanguageSelector.astro';
import PuentesSection from './PuentesSection.astro';
import { loadSettings, lightenColor } from '../lib/settings';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
const settings = loadSettings();
const primaryColor = settings.visual.primaryColor;
const secondaryColor = settings.visual.secondaryColor;
const primaryColorLight = lightenColor(primaryColor, 30);

const isCA = locale === 'ca';
const homeUrl = getLocalizedPath('/', locale);
const contactoUrl = getLocalizedPath('/contacto', locale);
const solucionesUrl = getLocalizedPath('/soluciones-ia-empresas', locale);
---

<!-- ═══════════════ TOP BAR (HUD) ═══════════════ -->
<div class="fixed top-0 left-0 right-0 z-50 bg-cyber-black border-b border-cyber-border">
  <div class="mx-auto max-w-7xl px-6 flex items-center justify-between h-8">
    <div class="flex items-center gap-4">
      <span class="hud-blink inline-block w-1.5 h-1.5 rounded-full bg-cyber-teal"></span>
      <span class="font-mono text-[9px] text-cyber-text/60 uppercase tracking-widest">{t.hud.sys_online}</span>
      <span class="font-mono text-[9px] text-cyber-border">|</span>
      <span class="font-mono text-[9px] text-cyber-teal/70">{t.hud.node_active}</span>
    </div>
    <div class="hidden sm:flex items-center gap-4">
      <span class="font-mono text-[9px] text-cyber-text/40">{t.hud.ping} <span class="text-cyber-teal/70">8ms</span></span>
      <span class="font-mono text-[9px] text-cyber-border">|</span>
      <span class="font-mono text-[9px] text-cyber-text/40">{t.hud.uptime} <span class="text-cyber-orange/70">99.9%</span></span>
      <span class="font-mono text-[9px] text-cyber-border">|</span>
      <span class="hud-blink inline-block w-1.5 h-1.5 rounded-full bg-cyber-red"></span>
      <span class="font-mono text-[9px] text-cyber-text/40">{t.hud.rec}</span>
    </div>
  </div>
</div>

<!-- ═══════════════ NAV ═══════════════ -->
<nav class="fixed top-8 left-0 right-0 z-50 border-b border-cyber-border bg-cyber-black/90 backdrop-blur-md">
  <div class="mx-auto max-w-7xl px-6 flex items-center justify-between h-16">
    <a href={homeUrl} class="flex items-center gap-1">
      <span class="text-lg font-bold tracking-tight text-cyber-white">CIBAI</span>
      <span class="text-lg font-bold tracking-tight text-cyber-orange">.</span>
      <span class="text-lg font-light tracking-tight text-cyber-orange">STUDIO</span>
    </a>
    <div class="flex items-center gap-6">
      <div class="hidden md:flex items-center gap-8">
        <a href={homeUrl} class="font-mono text-xs uppercase tracking-widest text-cyber-text hover:text-cyber-white transition-colors">{t.nav.inicio}</a>
        <a href={getLocalizedPath('/ia-automatizacion-empresas', locale)} class="font-mono text-xs uppercase tracking-widest text-cyber-orange transition-colors">{t.nav.servicios}</a>
        <a href={getLocalizedPath('/studio', locale)} class="font-mono text-xs uppercase tracking-widest text-cyber-text hover:text-cyber-white transition-colors">{t.nav.studio}</a>
      </div>
      <div class="flex items-center gap-3">
        <LanguageSelector currentLocale={locale} />
        <a href={contactoUrl} class="btn-primary text-xs py-2 px-5 hidden sm:inline-flex">{t.nav.proyecto}</a>
      </div>
    </div>
  </div>
</nav>

<!-- ═══════════════ HERO ═══════════════ -->
<section id="main-content" class="relative min-h-[60vh] flex flex-col justify-end pt-32 pb-16 overflow-hidden">
  <div class="absolute inset-0 opacity-[0.03]" style={`background-image: linear-gradient(color-mix(in srgb, ${primaryColor} 30%, transparent) 1px, transparent 1px), linear-gradient(90deg, color-mix(in srgb, ${primaryColor} 30%, transparent) 1px, transparent 1px); background-size: 60px 60px;`}></div>

  <div class="mx-auto max-w-7xl px-6 w-full">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 font-mono text-[10px] text-cyber-text/60 uppercase tracking-widest">
        <li><a href={homeUrl} class="hover:text-cyber-orange transition-colors">{isCA ? 'Inici' : 'Inicio'}</a></li>
        <li class="text-cyber-border">/</li>
        <li class="text-cyber-orange">{isCA ? 'Solucions IA per a Empreses' : 'Soluciones IA para Empresas'}</li>
      </ol>
    </nav>

    <div class="section-number mb-4">// {isCA ? 'SOLUCIONS' : 'SOLUCIONES'}</div>
    <h1 class="text-[clamp(2rem,5vw,4.5rem)] font-black leading-[0.95] tracking-tight mb-6 max-w-4xl">
      {isCA
        ? 'Solucions dissenyades per millorar com funciona la teva empresa'
        : 'Soluciones diseñadas para mejorar cómo funciona tu empresa'
      }
    </h1>
    <p class="text-cyber-text text-lg font-light max-w-2xl leading-relaxed mb-10">
      {isCA
        ? 'CIBAI.Studio resol problemes reals de negoci mitjançant IA, automatització, software a mida i actius digitals. Cada solució, adaptada al teu context.'
        : 'CIBAI.Studio resuelve problemas reales de negocio a través de IA, automatización, software a medida y activos digitales. Cada solución, adaptada a tu contexto.'
      }
    </p>
    <div class="flex flex-wrap gap-4">
      <a href={contactoUrl} class="btn-primary btn-glitch">
        {isCA ? 'Sol·licitar diagnòstic' : 'Solicitar diagnóstico'}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>

<!-- ═══════════════ QUÈ RESOLEM ═══════════════ -->
<section class="py-24 border-t border-cyber-border relative">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-16">
      <div class="section-number mb-4">// {isCA ? 'PROBLEMES' : 'PROBLEMAS'}</div>
      <h2 class="text-[clamp(2rem,4vw,3.5rem)] font-black leading-[0.95] tracking-tight">
        {isCA
          ? <><span>QUÈ</span><br/><span class="text-cyber-teal glow-teal">RESOLEM?</span></>
          : <><span>¿QUÉ</span><br/><span class="text-cyber-teal glow-teal">RESOLVEMOS?</span></>
        }
      </h2>
      <p class="text-cyber-text mt-4 max-w-2xl font-light leading-relaxed">
        {isCA
          ? 'La majoria d’empreses s’enfronten als mateixos reptes operatius. Aquí és on actuem.'
          : 'La mayoría de empresas se enfrentan a los mismos retos operativos. Aquí es donde actuamos.'
        }
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {[
        {
          num: '01',
          icon: '⚙️',
          title: isCA ? 'Ineficiència operativa' : 'Ineficiencia operativa',
          problem: isCA ? 'Tasques manuals que consumeixen temps' : 'Tareas manuales que consumen tiempo',
          desc: isCA
            ? 'El teu equip dedica hores a feines repetitives que podrien fer-se automàticament: enviaments, registres, aprovacions, notificacions.'
            : 'Tu equipo dedica horas a tareas repetitivas que podrían hacerse automáticamente: envíos, registros, aprobaciones, notificaciones.'
        },
        {
          num: '02',
          icon: '🔗',
          title: isCA ? 'Eines desconnectades' : 'Herramientas desconectadas',
          problem: isCA ? 'Sistemes que no parlen entre ells' : 'Sistemas que no se hablan entre sí',
          desc: isCA
            ? 'CRM, ERP, ecommerce, email, fulls de càlcul... La informació viu en silos i el teu equip perd temps movent dades a mà.'
            : 'CRM, ERP, ecommerce, email, hojas de cálculo... La información vive en silos y tu equipo pierde tiempo moviendo datos a mano.'
        },
        {
          num: '03',
          icon: '🤖',
          title: isCA ? 'Necessitat d’atenció intel·ligent' : 'Necesidad de atención inteligente',
          problem: isCA ? 'Clients i equip sense suport 24/7' : 'Clientes y equipo sin soporte 24/7',
          desc: isCA
            ? 'Les consultes s’acumulen, el servei al client no escala i el teu equip respon les mateixes preguntes una i altra vegada. Els agents IA i chatbots ho resolen.'
            : 'Las consultas se acumulan, el servicio al cliente no escala y tu equipo responde las mismas preguntas una y otra vez. Los agentes IA y chatbots lo resuelven.'
        },
        {
          num: '04',
          icon: '🌐',
          title: isCA ? 'Presència digital feble' : 'Presencia digital débil',
          problem: isCA ? 'Web i ecommerce que no converteixen' : 'Web y ecommerce que no convierten',
          desc: isCA
            ? 'Una presència digital que no reflecteix la qualitat del teu negoci, que carrega lenta o que no genera confiança, et fa perdre clients cada dia.'
            : 'Una presencia digital que no refleja la calidad de tu negocio, que carga lenta o que no genera confianza, te hace perder clientes cada día.'
        }
      ].map((item) => (
        <div class="card-brutal p-8">
          <div class="flex items-start gap-4 mb-4">
            <span class="text-3xl font-black text-cyber-orange/70">{item.num}</span>
            <div>
              <span class="font-mono text-[10px] text-cyber-teal uppercase tracking-widest block mb-1">{item.problem}</span>
              <h3 class="text-xl font-bold text-cyber-white">{item.title}</h3>
            </div>
          </div>
          <p class="text-sm text-cyber-text leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════ NOSTRES SOLUCIONS ═══════════════ -->
<section class="py-24 border-t border-cyber-border relative">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-16">
      <div class="section-number mb-4">// {isCA ? 'CATÀLEG' : 'CATÁLOGO'}</div>
      <h2 class="text-[clamp(2rem,4vw,3.5rem)] font-black leading-[0.95] tracking-tight">
        {isCA
          ? <><span>LES NOSTRES</span><br/><span class="text-cyber-orange glow-orange">SOLUCIONS</span></>
          : <><span>NUESTRAS</span><br/><span class="text-cyber-orange glow-orange">SOLUCIONES</span></>
        }
      </h2>
      <p class="text-cyber-text mt-4 max-w-2xl font-light leading-relaxed">
        {isCA
          ? 'Sis línies de servei especialitzades. Podem aplicar-les de forma aïllada o combinar-les per construir la solució completa que necessites.'
          : 'Seis líneas de servicio especializadas. Podemos aplicarlas de forma aislada o combinarlas para construir la solución completa que necesitas.'
        }
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        {
          num: '01',
          title: isCA ? 'IA i Automatització' : 'IA y Automatización',
          slug: '/ia-automatizacion-empresas',
          color: 'cyber-orange',
          tags: isCA ? ['AUTOMATITZACIÓ', 'FLUXOS', 'INTEGRACIONS'] : ['AUTOMATIZACIÓN', 'FLUJOS', 'INTEGRACIONES'],
          desc: isCA
            ? 'Reduïm tasques manuals, connectem eines i dissenyem fluxos intel·ligents per guanyar eficiència operativa real.'
            : 'Reducimos tareas manuales, conectamos herramientas y diseñamos flujos inteligentes para ganar eficiencia operativa real.'
        },
        {
          num: '02',
          title: isCA ? 'Agents IA i RAG' : 'Agentes IA y RAG',
          slug: '/agentes-ia-rag',
          color: 'cyber-teal',
          tags: isCA ? ['AGENTS', 'RAG', 'LLM'] : ['AGENTES', 'RAG', 'LLM'],
          desc: isCA
            ? 'Construïm agents IA i sistemes RAG que responen amb el coneixement del teu negoci: docs, dades, processos interns.'
            : 'Construimos agentes IA y sistemas RAG que responden con el conocimiento de tu negocio: docs, datos, procesos internos.'
        },
        {
          num: '03',
          title: isCA ? 'Veu IA i Centraletes' : 'Voz IA y Centralitas',
          slug: '/voz-ia-centralitas',
          color: 'cyber-orange',
          tags: isCA ? ['VEU', 'CENTRALETA', 'IA'] : ['VOZ', 'CENTRALITA', 'IA'],
          desc: isCA
            ? 'Sistemes de veu intel·ligents que atenen trucades, filtren consultes i gestionen la comunicació telefònica amb IA.'
            : 'Sistemas de voz inteligentes que atienden llamadas, filtran consultas y gestionan la comunicación telefónica con IA.'
        },
        {
          num: '04',
          title: isCA ? 'Software a Mida' : 'Software a Medida',
          slug: '/software-a-medida',
          color: 'cyber-teal',
          tags: isCA ? ['EINES INTERNES', 'ERP', 'PANELLS'] : ['HERRAMIENTAS', 'ERP', 'PANELES'],
          desc: isCA
            ? 'Desenvolupem eines internes, panells de gestió i aplicacions adaptades als teus processos reals. No plantilles.'
            : 'Desarrollamos herramientas internas, paneles de gestión y aplicaciones adaptadas a tus procesos reales. Sin plantillas.'
        },
        {
          num: '05',
          title: isCA ? 'Web Corporativa' : 'Web Corporativa',
          slug: '/web-corporativa',
          color: 'cyber-orange',
          tags: isCA ? ['WEB', 'DISSENY', 'RENDIMENT'] : ['WEB', 'DISEÑO', 'RENDIMIENTO'],
          desc: isCA
            ? 'Webs corporatives d’alt rendiment que transmeten credibilitat, generen confiança i converteixen visitants en clients.'
            : 'Webs corporativas de alto rendimiento que transmiten credibilidad, generan confianza y convierten visitantes en clientes.'
        },
        {
          num: '06',
          title: isCA ? 'Ecommerce a Mida' : 'Ecommerce a Medida',
          slug: '/ecommerce-a-medida',
          color: 'cyber-teal',
          tags: isCA ? ['ECOMMERCE', 'CONVERSIÓ', 'INTEGRACIÓ'] : ['ECOMMERCE', 'CONVERSIÓN', 'INTEGRACIÓN'],
          desc: isCA
            ? 'Botigues online dissenyades per vendre: experiència d’usuari, logística integrada i rendiment optimitzat des del primer dia.'
            : 'Tiendas online diseñadas para vender: experiencia de usuario, logística integrada y rendimiento optimizado desde el primer día.'
        }
      ].map((service) => (
        <a href={getLocalizedPath(service.slug, locale)} class="card-brutal p-8 group hover:border-cyber-orange/50 transition-all block">
          <div class="flex items-center justify-between mb-6">
            <span class="text-4xl font-black text-cyber-orange/50 group-hover:text-cyber-orange/80 transition-colors">{service.num}</span>
            <svg class="w-5 h-5 text-cyber-border group-hover:text-cyber-orange transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-cyber-white group-hover:text-cyber-orange transition-colors">{service.title}</h3>
          <p class="text-sm text-cyber-text leading-relaxed mb-5">{service.desc}</p>
          <div class="flex flex-wrap gap-2">
            {service.tags.map((tag: string) => (
              <span class="font-mono text-[9px] px-2 py-1 border border-cyber-border text-cyber-text/60">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════ COM HO FEM ═══════════════ -->
<section class="py-24 border-t border-cyber-border relative">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-16">
      <div class="section-number mb-4">// {isCA ? 'METODOLOGIA' : 'METODOLOGÍA'}</div>
      <h2 class="text-[clamp(2rem,4vw,3.5rem)] font-black leading-[0.95] tracking-tight">
        {isCA
          ? <><span>COM HO</span><br/><span class="text-cyber-teal glow-teal">FEM</span></>
          : <><span>CÓMO LO</span><br/><span class="text-cyber-teal glow-teal">HACEMOS</span></>
        }
      </h2>
      <p class="text-cyber-text mt-4 max-w-2xl font-light leading-relaxed">
        {isCA
          ? 'Un procés clar i estructurat per garantir que cada solució s’adapta exactament al que el teu negoci necessita.'
          : 'Un proceso claro y estructurado para garantizar que cada solución se adapta exactamente a lo que tu negocio necesita.'
        }
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-4">
      {[
        {
          num: '01',
          title: isCA ? 'Diagnòstic' : 'Diagnóstico',
          desc: isCA
            ? 'Analitzem la teva situació actual: processos, eines, punts de dolor i oportunitats de millora.'
            : 'Analizamos tu situación actual: procesos, herramientas, puntos de dolor y oportunidades de mejora.'
        },
        {
          num: '02',
          title: isCA ? 'Proposta' : 'Propuesta',
          desc: isCA
            ? 'Dissenyem la solució concreta: abast, tecnologies, terminis i pressupost clar.'
            : 'Diseñamos la solución concreta: alcance, tecnologías, plazos y presupuesto claro.'
        },
        {
          num: '03',
          title: isCA ? 'Implementació' : 'Implementación',
          desc: isCA
            ? 'Desenvolupem i configurem la solució de forma iterativa, amb validació contínua.'
            : 'Desarrollamos y configuramos la solución de forma iterativa, con validación continua.'
        },
        {
          num: '04',
          title: isCA ? 'Entrega' : 'Entrega',
          desc: isCA
            ? 'Posada en marxa en el teu entorn real, formació del teu equip i documentació completa.'
            : 'Puesta en marcha en tu entorno real, formación de tu equipo y documentación completa.'
        },
        {
          num: '05',
          title: isCA ? 'Suport' : 'Soporte',
          desc: isCA
            ? 'Acompanyament posterior, optimització contínua i suport tècnic per quan el necesites.'
            : 'Acompañamiento posterior, optimización continua y soporte técnico para cuando lo necesites.'
        }
      ].map((step) => (
        <div class="card-brutal p-6 group">
          <span class="text-4xl font-black text-cyber-orange/80 block mb-4">{step.num}</span>
          <h3 class="font-mono text-sm font-bold tracking-wider mb-3 text-cyber-white">{step.title}</h3>
          <p class="text-xs text-cyber-text leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<PuentesSection locale={locale} />

<!-- ═══════════════ CTA FINAL ═══════════════ -->
<section class="py-24 border-t border-cyber-border relative">
  <div class="absolute inset-0 opacity-[0.02]" style={`background-image: linear-gradient(color-mix(in srgb, ${secondaryColor} 20%, transparent) 1px, transparent 1px), linear-gradient(90deg, color-mix(in srgb, ${secondaryColor} 20%, transparent) 1px, transparent 1px); background-size: 40px 40px;`}></div>
  <div class="mx-auto max-w-7xl px-6 text-center relative">
    <div class="section-number mb-4 mx-auto w-fit">// {isCA ? 'DIAGNÒSTIC GRATUÏT' : 'DIAGNÓSTICO GRATUITO'}</div>
    <h2 class="text-[clamp(2rem,4vw,3.5rem)] font-black leading-tight mb-4">
      {isCA
        ? '¿No saps per on començar?'
        : '¿No sabes por dónde empezar?'
      }
    </h2>
    <p class="text-cyber-text max-w-xl mx-auto mb-10 font-light leading-relaxed">
      {isCA
        ? 'Parlem 30 minuts. Analitzem la teva empresa i t’expliquem exactament quines solucions tindrien més impacte, en quin ordre i amb quin cost aproximat.'
        : 'Hablamos 30 minutos. Analizamos tu empresa y te explicamos exactamente qué soluciones tendrían más impacto, en qué orden y con qué coste aproximado.'
      }
    </p>
    <a href={contactoUrl} class="btn-primary btn-glitch">
      {isCA ? 'Sol·licitar diagnòstic' : 'Solicitar diagnóstico'}
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    </a>
  </div>
</section>

<!-- ═══════════════ FOOTER ═══════════════ -->
<footer class="border-t border-cyber-border">
  <div class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div class="md:col-span-1">
        <div class="flex items-center gap-1 mb-4">
          <span class="text-lg font-bold text-cyber-white">CIBAI</span>
          <span class="text-lg font-bold text-cyber-orange">.</span>
          <span class="text-lg font-light text-cyber-orange">STUDIO</span>
        </div>
        <p class="text-sm text-cyber-text max-w-sm leading-relaxed mb-4">
          {t.footer.descripcion}
        </p>
      </div>
      <div>
        <div class="font-mono text-[10px] text-cyber-text uppercase tracking-widest mb-4">{t.footer.nav_label}</div>
        <div class="space-y-3">
          <a href={homeUrl} class="block text-sm text-cyber-text hover:text-cyber-white transition-colors">{t.footer.link_inicio}</a>
          <a href={getLocalizedPath('/ia-automatizacion-empresas', locale)} class="block text-sm text-cyber-text hover:text-cyber-white transition-colors">{t.footer.link_servicios}</a>
          <a href={getLocalizedPath('/casos-de-uso', locale)} class="block text-sm text-cyber-text hover:text-cyber-white transition-colors">{t.footer.link_casos_uso}</a>
          <a href={getLocalizedPath('/studio', locale)} class="block text-sm text-cyber-text hover:text-cyber-white transition-colors">{t.footer.link_studio}</a>
          <a href={contactoUrl} class="block text-sm text-cyber-text hover:text-cyber-white transition-colors">{t.footer.link_contacto}</a>
        </div>
      </div>
      <div>
        <div class="font-mono text-[10px] text-cyber-text uppercase tracking-widest mb-4">{t.footer.legal_label}</div>
        <div class="space-y-3">
          <a href={getLocalizedPath('/privacidad', locale)} class="block text-sm text-cyber-text hover:text-cyber-white transition-colors">{t.footer.link_privacidad}</a>
          <a href={getLocalizedPath('/aviso-legal', locale)} class="block text-sm text-cyber-text hover:text-cyber-white transition-colors">{t.footer.link_aviso}</a>
          <a href={getLocalizedPath('/cookies', locale)} class="block text-sm text-cyber-text hover:text-cyber-white transition-colors">{t.footer.link_cookies}</a>
        </div>
      </div>
    </div>
  </div>
  <div class="border-t border-cyber-border">
    <div class="mx-auto max-w-7xl px-6 py-4 flex flex-col md:flex-row items-center justify-between gap-2">
      <span class="font-mono text-[10px] text-cyber-text">{t.footer.copyright}</span>
      <span class="font-mono text-[10px] text-cyber-text">{t.footer.made_in}</span>
    </div>
