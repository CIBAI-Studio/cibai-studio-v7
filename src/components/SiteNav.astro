---
import type { Locale } from '../i18n';
import { getTranslations, getLocalizedPath } from '../i18n';
import LanguageSelector from './LanguageSelector.astro';

interface Props {
  locale: Locale;
  isHomePage?: boolean;
}

const { locale, isHomePage = false } = Astro.props;
const t = getTranslations(locale);

const homeUrl = getLocalizedPath('/', locale);
const anchor = (hash: string) => isHomePage ? hash : `${homeUrl}${hash}`;

const serviceDropdownLinks = [
  { label: t.nav.servicios_dropdown.inteligencia_artificial, href: getLocalizedPath('/soluciones-ia-empresas', locale) },
  { label: t.nav.servicios_dropdown.diseno_web, href: getLocalizedPath('/web-corporativa', locale) },
  { label: t.nav.servicios_dropdown.programacion_medida, href: getLocalizedPath('/software-a-medida', locale) },
  { label: t.nav.servicios_dropdown.automatizacion, href: getLocalizedPath('/ia-automatizacion-empresas', locale) },
  { label: t.nav.servicios_dropdown.neuromarketing_copy, href: `${homeUrl}#servicios` },
  { label: t.nav.servicios_dropdown.digital_business_growth, href: `${homeUrl}#servicios` },
];
const enTuIdiomaLinks = [
  { label: t.nav.en_tu_idioma_dropdown.tecnologia_util, href: anchor('#tecnologia-util') },
  { label: t.nav.en_tu_idioma_dropdown.el_problema, href: anchor('#problema') },
  { label: t.nav.en_tu_idioma_dropdown.resultados, href: anchor('#beneficios') },
];
---

<!-- ═══════════════ TOP BAR (HUD) ═══════════════ -->
<div class="fixed top-0 left-0 right-0 z-50 bg-cyber-black border-b border-cyber-border">
  <div class="mx-auto max-w-7xl px-6 flex items-center justify-between h-8">
    <div class="flex items-center gap-4">
      <span class="hud-blink inline-block w-1.5 h-1.5 rounded-full bg-cyber-teal"></span>
      <span class="font-mono text-[9px] text-cyber-text/60 uppercase tracking-widest">{t.hud.sys_online}</span>
      <span class="font-mono text-[9px] text-cyber-border">|</span>
      <span class="font-mono text-[9px] text-cyber-teal/70">{t.hud.node_active}</span>
      <span class="hud-blink-slow inline-block w-1 h-1 rounded-full bg-cyber-orange ml-1"></span>
    </div>
    <div class="hidden sm:flex items-center gap-4">
      <span class="font-mono text-[9px] text-cyber-text/40">{t.hud.ping} <span class="text-cyber-teal/70">8ms</span></span>
      <span class="font-mono text-[9px] text-cyber-border">|</span>
      <span class="font-mono text-[9px] text-cyber-text/40">{t.hud.uptime} <span class="text-cyber-orange/70">99.9%</span></span>
      <span class="font-mono text-[9px] text-cyber-border">|</span>
      <span class="hud-blink inline-block w-1.5 h-1.5 rounded-full bg-cyber-red"></span>
      <span class="font-mono text-[9px] text-cyber-text/40">{t.hud.rec}</span>
      <span class="font-mono text-[9px] text-cyber-border">|</span>
      <span class="font-mono text-[9px] text-cyber-text/40" id="hud-clock">00:00:00</span>
    </div>
  </div>
</div>

<!-- ═══════════════ NAV ═══════════════ -->
<nav class="fixed top-8 left-0 right-0 z-50 border-b border-cyber-border bg-cyber-black/90 backdrop-blur-md">
  <div class="mx-auto max-w-7xl px-6 flex items-center justify-between h-16">
    <a href={homeUrl} class="flex items-center gap-1">
      <span class="text-lg font-bold tracking-tight text-cyber-white">CIBAI</span>
      <span class="text-lg font-bold tracking-tight text-cyber-orange">.</span>
      <span class="text-lg font-light tracking-tight text-cyber-orange">STUDIO</span>
    </a>
    <div class="flex items-center gap-6">
      <div class="hidden md:flex items-center gap-8">
        <a href={anchor('#main-content')} class="font-mono text-xs uppercase tracking-widest text-cyber-text hover:text-cyber-white transition-colors">{t.nav.inicio}</a>
        <div class="relative group">
          <span class="font-mono text-xs uppercase tracking-widest text-cyber-text hover:text-cyber-white transition-colors flex items-center gap-1 cursor-pointer">
            {t.nav.en_tu_idioma}
            <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </span>
          <div class="absolute top-full left-0 mt-2 w-48 bg-cyber-black/95 backdrop-blur-md border border-cyber-border opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            {enTuIdiomaLinks.map((link) => (
              <a href={link.href} class="block px-4 py-2.5 font-mono text-[11px] uppercase tracking-wider text-cyber-text hover:text-cyber-orange hover:bg-cyber-dark/60 transition-colors border-b border-cyber-border/30 last:border-b-0">
                {link.label}
              </a>
            ))}
          </div>
        </div>
        <div class="relative group">
          <a href={anchor('#servicios')} class="font-mono text-xs uppercase tracking-widest text-cyber-text hover:text-cyber-white transition-colors flex items-center gap-1">
            {t.nav.servicios}
            <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </a>
          <div class="absolute top-full left-0 mt-2 w-56 bg-cyber-black/95 backdrop-blur-md border border-cyber-border opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            {serviceDropdownLinks.map((link) => (
              <a href={link.href} class="block px-4 py-2.5 font-mono text-[11px] uppercase tracking-wider text-cyber-text hover:text-cyber-orange hover:bg-cyber-dark/60 transition-colors border-b border-cyber-border/30 last:border-b-0">
                {link.label}
              </a>
            ))}
          </div>
        </div>
        <a href={anchor('#casos-uso')} class="font-mono text-xs uppercase tracking-widest text-cyber-text hover:text-cyber-white transition-colors">{t.nav.casos_uso}</a>
        <a href={anchor('#proceso')} class="font-mono text-xs uppercase tracking-widest text-cyber-text hover:text-cyber-white transition-colors">{t.nav.proceso}</a>
        <a href={anchor('#studio')} class="font-mono text-xs uppercase tracking-widest text-cyber-text hover:text-cyber-white transition-colors">{t.nav.studio}</a>
      </div>
      <div class="flex items-center gap-3">
        <LanguageSelector currentLocale={locale} />
        <a href={anchor('#contacto')} class="btn-primary text-xs py-2 px-5 hidden sm:inline-flex">{t.nav.proyecto}</a>
        <button
          id="mobile-menu-btn"
          class="md:hidden flex flex-col justify-center items-center w-10 h-10 border border-cyber-border hover:border-cyber-orange transition-colors"
          aria-label={t.nav.abrir_menu}
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="mobile-menu-line block w-5 h-px bg-cyber-white transition-all duration-300"></span>
          <span class="mobile-menu-line block w-5 h-px bg-cyber-white transition-all duration-300 mt-1.5"></span>
          <span class="mobile-menu-line block w-5 h-px bg-cyber-white transition-all duration-300 mt-1.5"></span>
        </button>
      </div>
    </div>
  </div>
  <div id="mobile-menu" class="md:hidden hidden border-t border-cyber-border bg-cyber-black/95 backdrop-blur-md">
    <div class="px-6 py-6 space-y-4">
      <a href={anchor('#main-content')} class="mobile-nav-link block font-mono text-sm uppercase tracking-widest text-cyber-text hover:text-cyber-orange transition-colors py-2">{t.nav.inicio}</a>
      <div>
        <button id="mobile-idioma-toggle" class="mobile-nav-link w-full text-left font-mono text-sm uppercase tracking-widest text-cyber-text hover:text-cyber-orange transition-colors py-2 flex items-center justify-between">
          {t.nav.en_tu_idioma}
          <svg class="w-3 h-3 transition-transform" id="mobile-idioma-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div id="mobile-idioma-submenu" class="hidden pl-4 space-y-1 pb-2">
          {enTuIdiomaLinks.map((link) => (
            <a href={link.href} class="mobile-nav-link block font-mono text-xs uppercase tracking-wider text-cyber-text/70 hover:text-cyber-orange transition-colors py-1.5">
              {link.label}
            </a>
          ))}
        </div>
      </div>
      <div>
        <button id="mobile-services-toggle" class="mobile-nav-link w-full text-left font-mono text-sm uppercase tracking-widest text-cyber-text hover:text-cyber-orange transition-colors py-2 flex items-center justify-between">
          {t.nav.servicios}
          <svg class="w-3 h-3 transition-transform" id="mobile-services-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div id="mobile-services-submenu" class="hidden pl-4 space-y-1 pb-2">
          {serviceDropdownLinks.map((link) => (
            <a href={link.href} class="mobile-nav-link block font-mono text-xs uppercase tracking-wider text-cyber-text/70 hover:text-cyber-orange transition-colors py-1.5">
              {link.label}
            </a>
          ))}
        </div>
      </div>
      <a href={anchor('#casos-uso')} class="mobile-nav-link block font-mono text-sm uppercase tracking-widest text-cyber-text hover:text-cyber-orange transition-colors py-2">{t.nav.casos_uso}</a>
      <a href={anchor('#proceso')} class="mobile-nav-link block font-mono text-sm uppercase tracking-widest text-cyber-text hover:text-cyber-orange transition-colors py-2">{t.nav.proceso}</a>
      <a href={anchor('#studio')} class="mobile-nav-link block font-mono text-sm uppercase tracking-widest text-cyber-text hover:text-cyber-orange transition-colors py-2">{t.nav.studio}</a>
      <a href={anchor('#contacto')} class="mobile-nav-link block font-mono text-sm uppercase tracking-widest text-cyber-text hover:text-cyber-orange transition-colors py-2">{t.nav.contacto}</a>
      <div class="pt-4 border-t border-cyber-border">
        <a href={anchor('#contacto')} class="btn-primary text-xs w-full justify-center">{t.nav.solicitar_proyecto}</a>
      </div>
    </div>
  </div>
</nav>
