---
import type { Locale } from '../i18n';
import { getTranslations, getLocalizedPath } from '../i18n';
import LanguageSelector from './LanguageSelector.astro';
import { loadSettings, lightenColor } from '../lib/settings';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
const settings = loadSettings();
const heroSlideDurationMs = settings.parameters.heroSlideDuration * 1000;
const serviceDropdownLinks = [
  { label: t.nav.servicios_dropdown.ia_automatizacion, href: getLocalizedPath('/ia-automatizacion-empresas', locale) },
  { label: t.nav.servicios_dropdown.agentes_ia, href: getLocalizedPath('/agentes-ia-rag', locale) },
  { label: t.nav.servicios_dropdown.voz_ia, href: getLocalizedPath('/voz-ia-centralitas', locale) },
  { label: t.nav.servicios_dropdown.software_medida, href: getLocalizedPath('/software-a-medida', locale) },
  { label: t.nav.servicios_dropdown.web_corporativa, href: getLocalizedPath('/web-corporativa', locale) },
  { label: t.nav.servicios_dropdown.ecommerce, href: getLocalizedPath('/ecommerce-a-medida', locale) },
];
const enTuIdiomaLinks = [
  { label: t.nav.en_tu_idioma_dropdown.tecnologia_util, href: '#tecnologia-util' },
  { label: t.nav.en_tu_idioma_dropdown.el_problema, href: '#problema' },
  { label: t.nav.en_tu_idioma_dropdown.resultados, href: '#beneficios' },
];
const primaryColor = settings.visual.primaryColor;
const secondaryColor = settings.visual.secondaryColor;
const primaryColorLight = lightenColor(primaryColor, 30);

// Hero slides: filtrar activos, ordenar por order, precomputar campos derivados
const heroSlides = settings.heroSlides.filter(s => s.active).sort((a, b) => a.order - b.order);
const processedHeroSlides = heroSlides.map((slide, idx) => ({
  ...slide,
  idx,
  isFirst: idx === 0,
  hd: slide.heading[locale] || slide.heading['es'] || { line1: '', line2: '', line3: '', full: '' },
  sub: slide.subtitle[locale] || slide.subtitle['es'] || '',
  term: slide.terminal[locale] || slide.terminal['es'] || { cmd: '', flag: '', lines: [] },
  bdg: slide.badges[locale] || slide.badges['es'] || ['', '', ''],
  accentClass: slide.accentColor === 'orange' ? 'text-cyber-orange' : 'text-cyber-teal',
  oppositeClass: slide.accentColor === 'orange' ? 'text-cyber-teal' : 'text-cyber-orange',
  glowClass: slide.accentColor === 'orange' ? 'glow-orange' : 'glow-teal',
  microcopyText: slide.microcopy ? (slide.microcopy[locale] || slide.microcopy['es'] || '') : '',
  durationMs: slide.duration * 1000,
}));

// Servicios: filtrar activos y ordenar
const activeServices = settings.services.filter(s => s.active !== false).sort((a, b) => (a.order ?? 0) - (b.order ?? 0));

const portfolioImages = [
  'https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=600&h=400&fit=crop',
  'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&h=400&fit=crop',
  'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&h=400&fit=crop',
  'https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=600&h=400&fit=crop',
];

const tickerItems = ['IA APLICADA', 'AUTOMATIZACIÓN', 'AGENTES IA', 'RAG', 'VOZ IA', 'SOFTWARE A MEDIDA', 'WEB CORPORATIVA', 'ECOMMERCE', 'DIAGNÓSTICO', 'IMPLANTACIÓN', 'PYTHON', 'NEXT.JS', 'TYPESCRIPT', 'POSTGRES'];
---

<!-- ═══════════════ TOP BAR (HUD) ═══════════════ -->
<div class="fixed top-0 left-0 right-0 z-50 bg-cyber-black border-b border-cyber-border">
  <div class="mx-auto max-w-7xl px-6 flex items-center justify-between h-8">
    <div class="flex items-center gap-4">
      <span class="hud-blink inline-block w-1.5 h-1.5 rounded-full bg-cyber-teal"></span>
      <span class="font-mono text-[9px] text-cyber-text/60 uppercase tracking-widest">{t.hud.sys_online}</span>
      <span class="font-mono text-[9px] text-cyber-border">|</span>
      <span class="font-mono text-[9px] text-cyber-teal/70">{t.hud.node_active}</span>
      <span class="hud-blink-slow inline-block w-1 h-1 rounded-full bg-cyber-orange ml-1"></span>
    </div>
    <div class="hidden sm:flex items-center gap-4">
      <span class="font-mono text-[9px] text-cyber-text/40">{t.hud.ping} <span class="text-cyber-teal/70">8ms</span></span>
      <span class="font-mono text-[9px] text-cyber-border">|</span>
      <span class="font-mono text-[9px] text-cyber-text/40">{t.hud.uptime} <span class="text-cyber-orange/70">99.9%</span></span>
      <span class="font-mono text-[9px] text-cyber-border">|</span>
      <span class="hud-blink inline-block w-1.5 h-1.5 rounded-full bg-cyber-red"></span>
      <span class="font-mono text-[9px] text-cyber-text/40">{t.hud.rec}</span>
      <span class="font-mono text-[9px] text-cyber-border">|</span>
      <span class="font-mono text-[9px] text-cyber-text/40" id="hud-clock">00:00:00</span>
    </div>
  </div>
</div>

<!-- ═══════════════ NAV ═══════════════ -->
<nav class="fixed top-8 left-0 right-0 z-50 border-b border-cyber-border bg-cyber-black/90 backdrop-blur-md">
  <div class="mx-auto max-w-7xl px-6 flex items-center justify-between h-16">
    <a href={getLocalizedPath('/', locale)} class="flex items-center gap-1">
      <span class="text-lg font-bold tracking-tight text-cyber-white">CIBAI</span>
      <span class="text-lg font-bold tracking-tight text-cyber-orange">.</span>
      <span class="text-lg font-light tracking-tight text-cyber-orange">STUDIO</span>
    </a>
    <div class="flex items-center gap-6">
      <div class="hidden md:flex items-center gap-8">
        <a href="#main-content" class="font-mono text-xs uppercase tracking-widest text-cyber-text hover:text-cyber-white transition-colors">{t.nav.inicio}</a>
        <div class="relative group">
          <span class="font-mono text-xs uppercase tracking-widest text-cyber-text hover:text-cyber-white transition-colors flex items-center gap-1 cursor-pointer">
            {t.nav.en_tu_idioma}
            <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </span>
          <div class="absolute top-full left-0 mt-2 w-48 bg-cyber-black/95 backdrop-blur-md border border-cyber-border opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            {enTuIdiomaLinks.map((link) => (
              <a href={link.href} class="block px-4 py-2.5 font-mono text-[11px] uppercase tracking-wider text-cyber-text hover:text-cyber-orange hover:bg-cyber-dark/60 transition-colors border-b border-cyber-border/30 last:border-b-0">
                {link.label}
              </a>
            ))}
          </div>
        </div>
        <div class="relative group">
          <a href="#servicios" class="font-mono text-xs uppercase tracking-widest text-cyber-text hover:text-cyber-white transition-colors flex items-center gap-1">
            {t.nav.servicios}
            <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </a>
          <div class="absolute top-full left-0 mt-2 w-56 bg-cyber-black/95 backdrop-blur-md border border-cyber-border opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            {serviceDropdownLinks.map((link) => (
              <a href={link.href} class="block px-4 py-2.5 font-mono text-[11px] uppercase tracking-wider text-cyber-text hover:text-cyber-orange hover:bg-cyber-dark/60 transition-colors border-b border-cyber-border/30 last:border-b-0">
                {link.label}
              </a>
            ))}
          </div>
        </div>
        <a href="#casos-uso" class="font-mono text-xs uppercase tracking-widest text-cyber-text hover:text-cyber-white transition-colors">{t.nav.casos_uso}</a>
        <a href="#proceso" class="font-mono text-xs uppercase tracking-widest text-cyber-text hover:text-cyber-white transition-colors">{t.nav.proceso}</a>
        <a href="#studio" class="font-mono text-xs uppercase tracking-widest text-cyber-text hover:text-cyber-white transition-colors">{t.nav.studio}</a>
      </div>
      <div class="flex items-center gap-3">
        <LanguageSelector currentLocale={locale} />
        <a href="#contacto" class="btn-primary text-xs py-2 px-5 hidden sm:inline-flex">{t.nav.proyecto}</a>
        <button
          id="mobile-menu-btn"
          class="md:hidden flex flex-col justify-center items-center w-10 h-10 border border-cyber-border hover:border-cyber-orange transition-colors"
          aria-label={t.nav.abrir_menu}
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="mobile-menu-line block w-5 h-px bg-cyber-white transition-all duration-300"></span>
          <span class="mobile-menu-line block w-5 h-px bg-cyber-white transition-all duration-300 mt-1.5"></span>
          <span class="mobile-menu-line block w-5 h-px bg-cyber-white transition-all duration-300 mt-1.5"></span>
        </button>
      </div>
    </div>
  </div>
  <div id="mobile-menu" class="md:hidden hidden border-t border-cyber-border bg-cyber-black/95 backdrop-blur-md">
    <div class="px-6 py-6 space-y-4">
      <a href="#main-content" class="mobile-nav-link block font-mono text-sm uppercase tracking-widest text-cyber-text hover:text-cyber-orange transition-colors py-2">{t.nav.inicio}</a>
      <div>
        <button id="mobile-idioma-toggle" class="mobile-nav-link w-full text-left font-mono text-sm uppercase tracking-widest text-cyber-text hover:text-cyber-orange transition-colors py-2 flex items-center justify-between">
          {t.nav.en_tu_idioma}
          <svg class="w-3 h-3 transition-transform" id="mobile-idioma-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div id="mobile-idioma-submenu" class="hidden pl-4 space-y-1 pb-2">
          {enTuIdiomaLinks.map((link) => (
            <a href={link.href} class="mobile-nav-link block font-mono text-xs uppercase tracking-wider text-cyber-text/70 hover:text-cyber-orange transition-colors py-1.5">
              {link.label}
            </a>
          ))}
        </div>
      </div>
      <div>
        <button id="mobile-services-toggle" class="mobile-nav-link w-full text-left font-mono text-sm uppercase tracking-widest text-cyber-text hover:text-cyber-orange transition-colors py-2 flex items-center justify-between">
          {t.nav.servicios}
          <svg class="w-3 h-3 transition-transform" id="mobile-services-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div id="mobile-services-submenu" class="hidden pl-4 space-y-1 pb-2">
          {serviceDropdownLinks.map((link) => (
            <a href={link.href} class="mobile-nav-link block font-mono text-xs uppercase tracking-wider text-cyber-text/70 hover:text-cyber-orange transition-colors py-1.5">
              {link.label}
            </a>
          ))}
        </div>
      </div>
      <a href="#casos-uso" class="mobile-nav-link block font-mono text-sm uppercase tracking-widest text-cyber-text hover:text-cyber-orange transition-colors py-2">{t.nav.casos_uso}</a>
      <a href="#proceso" class="mobile-nav-link block font-mono text-sm uppercase tracking-widest text-cyber-text hover:text-cyber-orange transition-colors py-2">{t.nav.proceso}</a>
      <a href="#studio" class="mobile-nav-link block font-mono text-sm uppercase tracking-widest text-cyber-text hover:text-cyber-orange transition-colors py-2">{t.nav.studio}</a>
      <a href="#contacto" class="mobile-nav-link block font-mono text-sm uppercase tracking-widest text-cyber-text hover:text-cyber-orange transition-colors py-2">{t.nav.contacto}</a>
      <div class="pt-4 border-t border-cyber-border">
        <a href="#contacto" class="btn-primary text-xs w-full justify-center">{t.nav.solicitar_proyecto}</a>
      </div>
    </div>
  </div>
</nav>

<!-- ═══════════════ HERO ═══════════════ -->
<section id="main-content" class="relative min-h-[90vh] flex flex-col justify-start pt-32 pb-8 overflow-hidden hero-section">
  <div class="absolute inset-0 opacity-[0.03] hero-bg-grid" style={`background-image: linear-gradient(color-mix(in srgb, ${primaryColor} 30%, transparent) 1px, transparent 1px), linear-gradient(90deg, color-mix(in srgb, ${primaryColor} 30%, transparent) 1px, transparent 1px); background-size: 60px 60px;`}></div>

  <div class="mx-auto max-w-7xl px-6 w-full">
    <div class="relative" style="min-height: 480px;" id="hero-slider">
      <div class="absolute top-0 right-0 flex items-center gap-4 z-10 animate-fade-in-up animate-delay-500">
        <div class="hero-slider-dots" id="hero-dots">
          {processedHeroSlides.map((slide) => (
            <button class={`hero-dot${slide.isFirst ? ' active' : ''}`} data-slide={slide.idx} aria-label={`Slide ${slide.idx + 1}`}></button>
          ))}
        </div>
        <div class="hero-slide-progress">
          <div class="hero-slide-progress-bar" id="hero-progress"></div>
        </div>
        <span class="font-mono text-[9px] text-cyber-text/50" id="hero-slide-counter">01 / {String(processedHeroSlides.length).padStart(2, '0')}</span>
      </div>

      <div class="max-w-4xl relative" style="min-height: 480px;">

        {processedHeroSlides.map((slide) => (
        <div class={`hero-slide${slide.isFirst ? ' active' : ''}`} id={`hero-slide-${slide.idx}`} data-duration={slide.durationMs}>

          {/* Badges */}
          <div class={`font-mono text-xs text-cyber-text mb-6${slide.isFirst ? ' animate-fade-in-up' : ''}`}>
            <span class={slide.accentClass}>{slide.bdg[0]}</span>
            <span class="mx-2 text-cyber-border">//</span>
            <span>{slide.bdg[1]}</span>
            <span class="mx-2 text-cyber-border">//</span>
            <span class={slide.oppositeClass}>{slide.bdg[2]}</span>
          </div>

          {/* Heading: h1 para el primero, h2 para el resto */}
          {slide.isFirst ? (
            <h1 class={`text-[clamp(1.8rem,5vw,5rem)] font-black leading-[0.92] tracking-tighter mb-6 animate-fade-in-up animate-delay-100 glitch-text`} data-text={slide.hd.full}>
              {slide.hd.line1}<br/>
              {slide.hd.line2}<br/>
              <span class={`${slide.accentClass} ${slide.glowClass}`}>{slide.hd.line3}</span>
            </h1>
          ) : (
            <h2 class="text-[clamp(1.8rem,5vw,5rem)] font-black leading-[0.92] tracking-tighter mb-6 glitch-text" data-text={slide.hd.full}>
              {slide.hd.line1}<br/>
              {slide.hd.line2}<br/>
              <span class={`${slide.accentClass} ${slide.glowClass}`}>{slide.hd.line3}</span>
            </h2>
          )}

          {/* Subtitle */}
          <p class={`text-base md:text-lg text-cyber-text/90 max-w-2xl leading-relaxed mb-6 font-light${slide.isFirst ? ' animate-fade-in-up animate-delay-150' : ''}`}>
            {slide.sub}
          </p>

          {/* Terminal */}
          <div class={`mb-8${slide.isFirst ? ' animate-fade-in-up animate-delay-200' : ''}`}>
            <div class="font-mono text-sm text-cyber-text max-w-xl leading-relaxed bg-cyber-dark/80 border border-cyber-border p-4">
              <span class="text-cyber-orange">$</span>
              <span class="text-cyber-teal ml-1">{slide.term.cmd}</span>
              <span class="text-cyber-text ml-1">{slide.term.flag}</span>
              {slide.isFirst ? (
                <div class="mt-2" id="typing-container">
                  <span id="typing-text" class="text-cyber-text/90"></span><span class="typing-cursor text-cyber-orange">█</span>
                </div>
              ) : (
                <div class="mt-2 text-cyber-text/90">
                  {slide.term.lines[0]}<br/>
                  {slide.term.lines[1] && <>{slide.term.lines[1]}<br/></>}
                  {slide.term.lines[2] && <span class={slide.accentClass}>{slide.term.lines[2]}</span>}
                </div>
              )}
            </div>
          </div>

          {/* Buttons */}
          <div class={`flex flex-wrap gap-4 mb-4${slide.isFirst ? ' animate-fade-in-up animate-delay-300' : ''}`}>
            {slide.buttons.map((btn) => (
              <a href={btn.href.startsWith('#') ? btn.href : getLocalizedPath(btn.href, locale)} class={`${btn.style === 'primary' ? 'btn-primary' : 'btn-secondary'} btn-glitch`}>
                {btn.label[locale] || btn.label['es']}
                {btn.style === 'primary' && (
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                )}
              </a>
            ))}
          </div>

          {/* Microcopy (solo primer slide) */}
          {slide.isFirst && slide.microcopyText && (
            <p class="font-mono text-[11px] text-cyber-text/40 max-w-lg leading-relaxed animate-fade-in-up animate-delay-400">
              {slide.microcopyText}
            </p>
          )}
        </div>
        ))}

      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
    <div class="w-px h-12 bg-gradient-to-b from-transparent to-cyber-orange/50"></div>
    <span class="font-mono text-[9px] text-cyber-text uppercase tracking-widest">{t.hero.scroll}</span>
  </div>
</section>

<!-- ═══════════════ TICKER ═══════════════ -->
<div class="border-y border-cyber-border py-4 overflow-hidden bg-cyber-dark/50">
  <div class="ticker-track">
    {[...tickerItems, ...tickerItems].map((item) => (
      <span class="inline-flex items-center gap-4 px-6 font-mono text-sm text-cyber-text whitespace-nowrap">
        <span class="ticker-sep flex-shrink-0 flex items-center gap-[2px] text-cyber-orange font-bold text-xs" aria-hidden="true">
          <span class="inline-block -skew-x-12">///</span>
        </span>
        {item}
      </span>
    ))}
  </div>
</div>

<!-- ═══════════════ BANDA CREDIBILIDAD ═══════════════ -->
<section id="tecnologia-util" class="py-24 border-b border-cyber-border relative overflow-hidden">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-[clamp(1.8rem,3.5vw,3rem)] font-black leading-tight tracking-tight mb-6">
          {t.banda_credibilidad.title}
        </h2>
        <p class="text-cyber-text leading-relaxed font-light max-w-lg">
          {t.banda_credibilidad.text}
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {t.banda_credibilidad.items.map((item: string) => (
          <div class="flex items-center gap-3 px-4 py-3 border border-cyber-border bg-cyber-dark/40">
            <span class="text-cyber-orange font-mono text-xs font-bold flex-shrink-0">///</span>
            <span class="font-mono text-[11px] text-cyber-text uppercase tracking-wider">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ DOLOR / PROBLEMA ═══════════════ -->
<section id="problema" class="py-32 border-b border-cyber-border relative">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <div>
        <div class="section-number mb-4">{t.dolor.section_label}</div>
        <h2 class="text-[clamp(2rem,4vw,3.5rem)] font-black leading-[1] tracking-tight mb-8">
          {t.dolor.title}
        </h2>
        <p class="text-cyber-text leading-relaxed mb-4 font-light">{t.dolor.text1}</p>
        <p class="text-cyber-text leading-relaxed mb-4 font-light">{t.dolor.text2}</p>
        <p class="text-cyber-orange font-mono text-sm font-bold mt-6">{t.dolor.text3}</p>
      </div>
      <div>
        <div class="font-mono text-[10px] text-cyber-text uppercase tracking-widest mb-6">{t.dolor.list_label}</div>
        <div class="space-y-0">
          {t.dolor.items.map((item: string, i: number) => (
            <div class="flex items-start gap-4 py-4 border-b border-cyber-border/40 group hover:border-cyber-orange/30 transition-colors">
              <span class="text-cyber-orange font-mono text-xs font-black flex-shrink-0 mt-0.5">
                {String(i + 1).padStart(2, '0')}
              </span>
              <p class="text-sm text-cyber-text/90 leading-relaxed group-hover:text-cyber-white transition-colors">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ BENEFICIOS 01–06 (Efecto Zeigarnik) ═══════════════ -->
<section id="beneficios" class="py-32 border-b border-cyber-border relative">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-16">
      <div class="section-number mb-4">{t.beneficios.section_label}</div>
      <h2 class="text-[clamp(2.5rem,5vw,4.5rem)] font-black leading-[0.95] tracking-tight mb-4 max-w-3xl">
        {t.beneficios.title}
      </h2>
      <p class="text-cyber-text font-light max-w-lg">{t.beneficios.intro}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {t.beneficios.items.map((item: any) => (
        <div class="card-brutal p-8 group relative overflow-hidden">
          <div class="absolute top-0 left-0 w-1 h-full bg-cyber-orange/20 group-hover:bg-cyber-orange/60 transition-colors duration-300"></div>
          <span class="text-5xl font-black text-cyber-orange block mb-4 leading-none">{item.num}</span>
          <h3 class="text-lg font-bold tracking-tight mb-3 text-cyber-white">{item.title}</h3>
          <p class="text-sm text-cyber-text leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════ SERVICIOS ═══════════════ -->
<section id="servicios" class="py-32 relative">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-16">
      <div class="section-number mb-4">{t.servicios.section_label}</div>
