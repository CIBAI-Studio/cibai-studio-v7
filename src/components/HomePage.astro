<section id="contacto" class="py-32 border-t border-cyber-border relative">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-16">
      <div class="section-number mb-4">{t.contacto.section_label}</div>
      <h2 class="text-[clamp(1.8rem,3.5vw,3rem)] font-black leading-tight mb-4 max-w-2xl">
        {t.contacto.title}
      </h2>
      <p class="text-cyber-text max-w-xl font-light leading-relaxed">
        {t.contacto.subtitle}
      </p>
      <p class="text-sm text-cyber-text/60 max-w-xl font-light leading-relaxed mt-3">
        {t.contacto.support_text}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <div class="card-brutal p-8">
        <form id="contact-form" class="space-y-5" action="mailto:hola@cibai.studio" method="POST" enctype="text/plain">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="contact-name" class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-2">{t.contacto.label_nombre}</label>
              <input type="text" id="contact-name" name="nombre" required
                class="w-full bg-cyber-black border border-cyber-border px-4 py-3 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors placeholder:text-cyber-text/30"
                placeholder={t.contacto.placeholder_nombre} />
            </div>
            <div>
              <label for="contact-empresa" class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-2">{t.contacto.label_empresa}</label>
              <input type="text" id="contact-empresa" name="empresa"
                class="w-full bg-cyber-black border border-cyber-border px-4 py-3 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors placeholder:text-cyber-text/30"
                placeholder={t.contacto.placeholder_empresa} />
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="contact-email" class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-2">{t.contacto.label_email}</label>
              <input type="email" id="contact-email" name="email" required
                class="w-full bg-cyber-black border border-cyber-border px-4 py-3 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors placeholder:text-cyber-text/30"
                placeholder={t.contacto.placeholder_email} />
            </div>
            <div>
              <label for="contact-telefono" class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-2">{t.contacto.label_telefono}</label>
              <input type="tel" id="contact-telefono" name="telefono"
                class="w-full bg-cyber-black border border-cyber-border px-4 py-3 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors placeholder:text-cyber-text/30"
                placeholder={t.contacto.placeholder_telefono} />
            </div>
          </div>
          <div>
            <label for="contact-project" class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-2">{t.contacto.label_proyecto}</label>
            <select id="contact-project" name="proyecto"
              class="w-full bg-cyber-black border border-cyber-border px-4 py-3 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors">
              <option value="ia_automatizacion">{t.contacto.option_ia_automatizacion}</option>
              <option value="agentes_ia">{t.contacto.option_agentes_ia}</option>
              <option value="voz_ia">{t.contacto.option_voz_ia}</option>
              <option value="software">{t.contacto.option_software}</option>
              <option value="web">{t.contacto.option_web}</option>
              <option value="ecommerce">{t.contacto.option_ecommerce}</option>
              <option value="otro">{t.contacto.option_otro}</option>
            </select>
          </div>
          <div>
            <label for="contact-message" class="font-mono text-[10px] text-cyber-text uppercase tracking-widest block mb-2">{t.contacto.label_mensaje}</label>
            <textarea id="contact-message" name="mensaje" rows="4" required
              class="w-full bg-cyber-black border border-cyber-border px-4 py-3 font-mono text-sm text-cyber-white focus:border-cyber-orange focus:outline-none transition-colors resize-none placeholder:text-cyber-text/30"
              placeholder={t.contacto.placeholder_mensaje}></textarea>
            <p class="font-mono text-[9px] text-cyber-text/40 mt-2">{t.contacto.microcopy_form}</p>
          </div>
          <button type="submit" class="btn-primary w-full justify-center">
            {t.contacto.btn_enviar}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </button>
        </form>
      </div>

      <div class="card-brutal p-0 overflow-hidden flex flex-col">
        <div class="flex items-center gap-2 px-4 py-3 border-b border-cyber-border bg-cyber-gray/50">
          <span class="w-2.5 h-2.5 rounded-full bg-cyber-red/80"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-cyber-orange/80"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-cyber-teal/80"></span>
          <span class="font-mono text-[10px] text-cyber-text/60 ml-2">{t.contacto.terminal_path}</span>
        </div>
        <div class="p-6 font-mono text-xs leading-relaxed flex-1 overflow-auto" id="terminal-output">
          <div class="text-cyber-teal">$ cat info.txt</div>
          <div class="mt-2 text-cyber-text/80">
            <div><span class="text-cyber-orange">EMPRESA:</span> {t.contacto.terminal_empresa}</div>
            <div><span class="text-cyber-orange">UBICACIÓN:</span> {t.contacto.terminal_ubicacion}</div>
            <div><span class="text-cyber-orange">EMAIL:</span> {t.contacto.terminal_email}</div>
            <div><span class="text-cyber-orange">HORARIO:</span> {t.contacto.terminal_horario}</div>
            <div><span class="text-cyber-orange">STATUS:</span> <span class="text-cyber-teal">{t.contacto.terminal_status}</span></div>
          </div>
          <div class="mt-4 text-cyber-teal">$ uptime</div>
          <div class="mt-1 text-cyber-text/80">{t.contacto.terminal_uptime}</div>
          <div class="mt-4 text-cyber-teal">$ cat respuesta.md</div>
          <div class="mt-1 text-cyber-text/80">
            <div>{t.contacto.terminal_respuesta1}</div>
            <div>{t.contacto.terminal_respuesta2}</div>
            <div>{t.contacto.terminal_respuesta3}</div>
          </div>
          <div class="mt-4 text-cyber-teal">$ <span class="typing-cursor text-cyber-orange">█</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

