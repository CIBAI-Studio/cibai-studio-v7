<script define:vars={{ typingLines: (processedHeroSlides.length > 0 && processedHeroSlides[0].term.lines.length > 0) ? processedHeroSlides[0].term.lines : [t.hero.typing_line1, t.hero.typing_line2, t.hero.typing_line3], formSuccess: t.contacto.form_success, heroSlideDurationMs }}>
  // ── Mobile menu ──────────────────────────────────────────────────────────────
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      menuBtn.setAttribute('aria-expanded', String(!isOpen));
      const lines = menuBtn.querySelectorAll('.mobile-menu-line');
      if (!isOpen) {
        lines[0]?.classList.add('translate-y-[4px]', 'rotate-45');
        lines[1]?.classList.add('opacity-0');
        lines[2]?.classList.add('-translate-y-[4px]', '-rotate-45');
      } else {
        lines[0]?.classList.remove('translate-y-[4px]', 'rotate-45');
        lines[1]?.classList.remove('opacity-0');
        lines[2]?.classList.remove('-translate-y-[4px]', '-rotate-45');
      }
    });
    mobileMenu.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
        const lines = menuBtn.querySelectorAll('.mobile-menu-line');
        lines[0]?.classList.remove('translate-y-[4px]', 'rotate-45');
        lines[1]?.classList.remove('opacity-0');
        lines[2]?.classList.remove('-translate-y-[4px]', '-rotate-45');
      });
    });
  }

  // ── Mobile "En tu idioma" submenu toggle ─────────────────────────────────────
  const idiomaToggle = document.getElementById('mobile-idioma-toggle');
  const idiomaSubmenu = document.getElementById('mobile-idioma-submenu');
  const idiomaChevron = document.getElementById('mobile-idioma-chevron');
  if (idiomaToggle && idiomaSubmenu && idiomaChevron) {
    idiomaToggle.addEventListener('click', () => {
      idiomaSubmenu.classList.toggle('hidden');
      idiomaChevron.classList.toggle('rotate-180');
    });
  }

  // ── Mobile services submenu toggle ──────────────────────────────────────────
  const svcToggle = document.getElementById('mobile-services-toggle');
  const svcSubmenu = document.getElementById('mobile-services-submenu');
  const svcChevron = document.getElementById('mobile-services-chevron');
  if (svcToggle && svcSubmenu && svcChevron) {
    svcToggle.addEventListener('click', () => {
      svcSubmenu.classList.toggle('hidden');
      svcChevron.classList.toggle('rotate-180');
    });
  }

  // ── Smooth scroll ───��─────────────────────────────────────────────────────────
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      e.preventDefault();
      const href = this.getAttribute('href');
      if (href) {
        const target = document.querySelector(href);
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // ── HUD Clock ─────────────────────────────────────────────────────────────────
  function updateClock() {
    const now = new Date();
    const h = String(now.getHours()).padStart(2, '0');
    const m = String(now.getMinutes()).padStart(2, '0');
    const s = String(now.getSeconds()).padStart(2, '0');
    const el = document.getElementById('hud-clock');
    if (el) el.textContent = `${h}:${m}:${s}`;
  }
  updateClock();
  setInterval(updateClock, 1000);

  // ── Hero slider — data-driven con duración por slide ─────────────────────────
  let currentSlide = 0;
  let sliderTimeout = null;
  let progressStart = null;
  let animFrame = null;

  function getSlideDuration() {
    const slides = document.querySelectorAll('.hero-slide');
    const slide = slides[currentSlide];
    return slide ? parseInt(slide.dataset.duration || String(heroSlideDurationMs)) : heroSlideDurationMs;
  }

  function goToSlide(idx) {
    const slides = document.querySelectorAll('.hero-slide');
    const dots = document.querySelectorAll('.hero-dot');
    const counter = document.getElementById('hero-slide-counter');
    slides.forEach((s, i) => s.classList.toggle('active', i === idx));
    dots.forEach((d, i) => d.classList.toggle('active', i === idx));
    if (counter) counter.textContent = `${String(idx + 1).padStart(2, '0')} / ${String(slides.length).padStart(2, '0')}`;
    currentSlide = idx;
    scheduleNext();
    resetProgressBar();
  }

  function resetProgressBar() {
    if (animFrame) cancelAnimationFrame(animFrame);
    const bar = document.getElementById('hero-progress');
    if (!bar) return;
    bar.style.transform = 'scaleX(0)';
    progressStart = performance.now();
    animateProgress(bar, getSlideDuration());
  }

  function animateProgress(bar, dur) {
    animFrame = requestAnimationFrame((now) => {
      const elapsed = now - progressStart;
      const ratio = Math.min(elapsed / dur, 1);
      bar.style.transform = `scaleX(${ratio})`;
      if (ratio < 1) animateProgress(bar, dur);
    });
  }

  function scheduleNext() {
    if (sliderTimeout) clearTimeout(sliderTimeout);
    const slides = document.querySelectorAll('.hero-slide');
    if (slides.length <= 1) return;
    const dur = getSlideDuration();
    sliderTimeout = setTimeout(() => {
      goToSlide((currentSlide + 1) % slides.length);
    }, dur);
  }

  document.querySelectorAll('.hero-dot').forEach((dot) => {
    dot.addEventListener('click', () => {
      goToSlide(parseInt(dot.getAttribute('data-slide') || '0'));
    });
  });

  // Arrancar carousel
  scheduleNext();
  resetProgressBar();

  // ── Typing effect (Slide 1) ───────────────────────────────────────────────────
  let charIndex = 0;
  let lineIndex = 0;
  let isDeleting = false;
  const typingEl = document.getElementById('typing-text');

  function typeEffect() {
    if (!typingEl) return;
    const currentLine = typingLines[lineIndex];
    if (!isDeleting) {
      typingEl.textContent = currentLine.substring(0, charIndex + 1);
      charIndex++;
      if (charIndex === currentLine.length) {
        isDeleting = true;
        setTimeout(typeEffect, 2000);
        return;
      }
    } else {
      typingEl.textContent = currentLine.substring(0, charIndex - 1);
      charIndex--;
      if (charIndex === 0) {
        isDeleting = false;
        lineIndex = (lineIndex + 1) % typingLines.length;
      }
    }
    setTimeout(typeEffect, isDeleting ? 40 : 60);
  }
  setTimeout(typeEffect, 800);

  // ── FAQ accordion ─────────────────────────────────────────────────────────────
  document.querySelectorAll('.faq-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item');
      const content = item?.querySelector('.faq-content');
      const icon = trigger.querySelector('.faq-icon svg');
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      document.querySelectorAll('.faq-trigger').forEach(t => {
        t.setAttribute('aria-expanded', 'false');
        t.closest('.faq-item')?.querySelector('.faq-content')?.classList.add('hidden');
        t.querySelector('.faq-icon svg')?.classList.remove('rotate-45');
      });

      if (!isOpen) {
        trigger.setAttribute('aria-expanded', 'true');
        content?.classList.remove('hidden');
        icon?.classList.add('rotate-45');
      }
    });
  });

  // ── Contact form ──────────────────────────────────────────────────────────────
  const contactForm = document.getElementById('contact-form');
  if (contactForm) {
    contactForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const terminalOutput = document.getElementById('terminal-output');
      if (terminalOutput) {
        const successMsg = document.createElement('div');
        successMsg.className = 'mt-4 text-cyber-teal font-mono text-xs leading-relaxed border border-cyber-teal/30 p-3 bg-cyber-teal/5';
        successMsg.textContent = formSuccess;
        terminalOutput.appendChild(successMsg);
        terminalOutput.scrollTop = terminalOutput.scrollHeight;
      }
      contactForm.reset();
    });
  }
</script>
